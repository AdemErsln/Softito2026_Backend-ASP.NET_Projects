@{
    Layout = "/Views/Shared/admin.cshtml";
}

@{
    ViewData["Title"] = "Yatırımcı Yönetimi";
 
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="text-white fw-bold mb-1">Yatırımcı Listesi</h4>
        <p class="text-secondary small mb-0">Sistemde kayıtlı franchise alıcılarını yönetin ve paket atamalarını yapın.</p>
    </div>
    <div class="d-flex gap-2">
        <a href="/Admin/ExportBuyersToExcel" class="btn btn-outline-success px-3 py-2 rounded-3 fw-semibold border-success text-success bg-success bg-opacity-10" style="text-decoration: none; display: inline-flex; align-items: center;">
            <i class="fa-solid fa-file-excel me-2"></i> Excel Çıktısı
        </a>
        <a href="/Admin/ExportBuyersToPdf" class="btn btn-outline-danger px-3 py-2 rounded-3 fw-semibold border-danger text-danger bg-danger bg-opacity-10" style="text-decoration: none; display: inline-flex; align-items: center;">
            <i class="fa-solid fa-file-pdf me-2"></i> PDF Raporu
        </a>
        <button class="btn btn-indigo px-4 py-2 rounded-3 fw-semibold text-white" style="background-color: #6366f1;" onclick="openAddModal()">
            <i class="fa-solid fa-plus me-2"></i> Yeni Yatırımcı Ekle
        </button>
    </div>
</div>

<div class="mb-4" style="max-width: 400px;">
    <div class="position-relative">
        <i class="fa-solid fa-magnifying-glass text-secondary position-absolute top-50 translate-middle-y ms-3"></i>
        <input type="text" id="buyerSearchInput" class="form-control bg-dark border-secondary border-opacity-20 text-white rounded-3 py-2 ps-5" placeholder="Yatırımcı adı veya notlarda ara...">
    </div>
</div>

<div class="p-4 rounded-4" style="background-color: rgba(11, 12, 16, 0.4); border: 1px solid rgba(255, 255, 255, 0.04);">
    <div class="table-responsive">
        <table class="table table-dark table-hover align-middle mb-0" style="--bs-table-bg: transparent; --bs-table-border-color: rgba(255,255,255,0.03);">
            <thead>
                <tr class="text-secondary small text-uppercase">
                    <th class="py-3" style="width: 80px;">ID</th>
                    <th class="py-3">Yatırımcı / Firma Adı</th>
                    <th class="py-3">Mevcut Paket</th>
                    <th class="py-3">Notlar</th>
                    <th class="py-3 text-end">Aksiyonlar</th>
                </tr>
            </thead>
            <tbody id="buyers-table-body">
                <tr>
                    <td colspan="5" class="text-center py-5 text-secondary">
                        <div class="spinner-border spinner-border-sm text-indigo me-2" role="status"></div>
                        Yatırımcılar yükleniyor...
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="buyerModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content text-white rounded-4" style="background-color: #0b0c10; border: 1px solid rgba(255, 255, 255, 0.08);">
            <div class="modal-header border-bottom border-dark border-opacity-50 py-3 px-4">
                <h5 class="modal-title fw-bold" id="modalTitle">Yatırımcı Ekle</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <form id="buyerForm">
                    <input type="hidden" id="buyerId" name="BuyerID" />

                    <div class="mb-3">
                        <label class="form-label text-secondary small text-uppercase fw-bold">Yatırımcı / Firma Adı</label>
                        <input type="text" class="form-control bg-dark border-secondary border-opacity-20 text-white rounded-3 py-2" id="buyerName" name="BuyerName" required placeholder="Örn: Ahmet Yılmaz / Yılmaz Grup">
                    </div>

                    <div class="mb-3">
                        <label class="form-label text-secondary small text-uppercase fw-bold">Notlar</label>
                        <textarea class="form-control bg-dark border-secondary border-opacity-20 text-white rounded-3 py-2" id="buyerNotes" name="Notes" rows="3" placeholder="Yatırımcı ile ilgili özel notlar..."></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-top border-dark border-opacity-50 p-3 px-4">
                <button type="button" class="btn btn-dark border border-secondary border-opacity-20 px-4 py-2 rounded-3 fw-semibold" data-bs-dismiss="modal">İptal</button>
                <button type="button" class="btn text-white px-4 py-2 rounded-3 fw-semibold" style="background-color: #6366f1;" onclick="saveBuyer()">Kaydet</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var buyerModal;

        $(document).ready(function () {
            buyerModal = new bootstrap.Modal(document.getElementById('buyerModal'));
            loadBuyers();

            // 🟢 YENİ: Canlı Yatırımcı Arama Dinleyicisi
            $('#buyerSearchInput').on('keyup', function () {
                var value = $(this).val().toLowerCase();

                $('#buyers-table-body tr').filter(function () {
                    $(this).toggle($(this).text().toLowerCase().indexOf(value) > -1);
                });
            });
        });

        // 1. LİSTELEME
        function loadBuyers() {
            $.ajax({
                url: '/Admin/GetBuyers',
                type: 'GET',
                dataType: 'json',
                success: function (response) {
                    var html = '';
                    if (response && response.length > 0) {
                        $.each(response, function (index, buyer) {
                            var packageBadge = buyer.packageName
                                ? `<span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-20 px-3 py-1 rounded-pill">${buyer.packageName}</span>`
                                : `<span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-20 px-3 py-1 rounded-pill">Paket Seçilmedi</span>`;

                            html += `
                                <tr id="buyer-row-${buyer.buyerID}">
                                    <td class="text-secondary fw-medium">#${buyer.buyerID}</td>
                                    <td><div class="fw-semibold text-white">${buyer.buyerName}</div></td>
                                    <td>${packageBadge}</td>
                                    <td class="text-secondary small text-truncate" style="max-width: 250px;">${buyer.notes || '—'}</td>
                                    <td class="text-end">
                                        <div class="d-flex justify-content-end gap-2">
                                            <button class="btn btn-sm btn-action btn-edit border border-secondary border-opacity-20 text-white" onclick="editBuyer(${buyer.buyerID})">
                                                <i class="fa-solid fa-pen-to-square"></i>
                                            </button>
                                            <button class="btn btn-sm btn-action btn-delete border border-danger border-opacity-20 text-danger" onclick="deleteBuyer(${buyer.buyerID})">
                                                <i class="fa-solid fa-trash-can"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            `;
                        });
                    } else {
                        html = `<tr><td colspan="5" class="text-center py-5 text-secondary">Kayıtlı yatırımcı bulunamadı.</td></tr>`;
                    }
                    $('#buyers-table-body').html(html);

                    // Arama girdisi varken liste yenilenirse filtreyi koru
                    $('#buyerSearchInput').trigger('keyup');
                }
            });
        }

        // 2. EKLEME MODALINI AÇ
        function openAddModal() {
            $('#buyerForm')[0].reset();
            $('#buyerId').val('');
            $('#modalTitle').text('Yeni Yatırımcı Ekle');
            buyerModal.show();
        }

        // 3. DÜZENLEME VERİSİNİ GETİR
        function editBuyer(id) {
            $.ajax({
                url: '/Admin/GetBuyerById',
                type: 'GET',
                data: { id: id },
                success: function(buyer) {
                    if(buyer) {
                        $('#buyerId').val(buyer.buyerID);
                        $('#buyerName').val(buyer.buyerName);
                        $('#buyerNotes').val(buyer.notes);
                        $('#modalTitle').text('Yatırımcıyı Düzenle');
                        buyerModal.show();
                    }
                }
            });
        }

        // 4. KAYDET
        function saveBuyer() {
            var formData = $('#buyerForm').serialize();
            var id = $('#buyerId').val();
            var targetUrl = id ? '/Admin/UpdateBuyer' : '/Admin/AddBuyer';

            $.ajax({
                url: targetUrl,
                type: 'POST',
                data: formData,
                success: function (response) {
                    if (response.success) {
                        buyerModal.hide();
                        loadBuyers();
                    } else {
                        alert(response.message || "İşlem başarısız.");
                    }
                }
            });
        }

        // 5. SİLME
        function deleteBuyer(id) {
            if (confirm("Bu yatırımcıyı silmek istediğinize emin misiniz?")) {
                $.ajax({
                    url: '/Admin/DeleteBuyer',
                    type: 'POST',
                    data: { id: id },
                    success: function (response) {
                        if (response.success) {
                            $(`#buyer-row-${id}`).fadeOut(400, function() { $(this).remove(); });
                        }
                    }
                });
            }
        }
    </script>

    <style>
        .btn-action {
            background-color: transparent !important;
            width: 36px;
            height: 36px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 8px;
            transition: all 0.2s ease;
        }

        .btn-edit:hover {
            background-color: rgba(255, 255, 255, 0.05) !important;
            border-color: #fff !important;
        }

        .btn-delete:hover {
            background-color: #dc3545 !important;
            color: #fff !important;
            border-color: #dc3545 !important;
            box-shadow: 0 0 10px rgba(220, 53, 69, 0.4);
        }

        .btn-indigo:hover {
            background-color: #4f46e5 !important;
            box-shadow: 0 0 15px rgba(99, 102, 241, 0.4);
        }

        .form-control:focus {
            background-color: #111318 !important;
            color: #fff;
            border-color: #6366f1 !important;
            box-shadow: 0 0 10px rgba(99, 102, 241, 0.2);
        }
    </style>
}