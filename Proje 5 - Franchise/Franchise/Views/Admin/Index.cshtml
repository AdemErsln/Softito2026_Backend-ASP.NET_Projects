                </div>
            </div>
            <h2 class="text-white fw-extrabold mb-1">452</h2>
            <span class="text-secondary small">Şu an kullanımda olan</span>
        </div>
    </div>

    <div class="col-md-4">
        <div class="p-4 rounded-4" style="background-color: rgba(11, 12, 16, 0.4); border: 1px solid rgba(255, 255, 255, 0.04);">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <span class="text-secondary small text-uppercase fw-bold tracking-wider">Toplam Hacim</span>
                <div class="rounded-3 p-2" style="background-color: rgba(245, 158, 11, 0.1); color: #f59e0b;">
