<div class="row g-4 mb-5">
    <div class="col-md-4">
        <div class="p-4 rounded-4" style="background-color: rgba(11, 12, 16, 0.4); border: 1px solid rgba(255, 255, 255, 0.04); position: relative; overflow: hidden;">
            <div class="d-flex justify-content-between align-items-center mb-3">
