                <div class="rounded-3 p-2" style="background-color: rgba(99, 102, 241, 0.1); color: #6366f1;">
                    <i class="fa-solid fa-users fs-5"></i>
                </div>
            </div>
            <h2 class="text-white fw-extrabold mb-1">1,248</h2>
