@model DiscordClone.Models.Friendship

@{
    ViewData["Title"] = "Arkadaşlık Ekle";
}

<div class="card bg-dark text-white border-secondary p-4" style="max-width: 600px;">
    <h4 class="fw-bold text-white mb-4"><i class="bi bi-plus-circle text-primary me-2"></i>Yeni İlişki Ekle</h4>

    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="SenderId" class="form-label">Gönderen Kullanıcı</label>
            <select asp-for="SenderId" asp-items="ViewBag.UserList" class="form-select" required>
                <option disabled selected>-- Gönderen Seçin --</option>
            </select>
            <span asp-validation-for="SenderId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="ReceiverId" class="form-label">Alıcı Kullanıcı</label>
            <select asp-for="ReceiverId" asp-items="ViewBag.UserList" class="form-select" required>
                <option disabled selected>-- Alıcı Seçin --</option>
            </select>
            <span asp-validation-for="ReceiverId" class="text-danger"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Status" class="form-label">Durum</label>
            <select asp-for="Status" class="form-select" required>
                <option value="@FriendshipStatus.Pending">Beklemede (Pending)</option>
                <option value="@FriendshipStatus.Accepted">Kabul Edildi (Accepted)</option>
                <option value="@FriendshipStatus.Blocked">Engellendi (Blocked)</option>
            </select>
            <span asp-validation-for="Status" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-discord-primary px-4">Oluştur</button>
            <a asp-action="Index" class="btn btn-outline-light px-4">İptal</a>
        </div>
    </form>
</div>
