@model IEnumerable<DiscordClone.Models.ServerMember>

@{
    ViewData["Title"] = "Sunucu Üye Yönetimi";
}

<div class="card bg-dark text-white border-secondary p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold text-white"><i class="bi bi-person-badge text-primary me-2"></i>Sunucu Üyeleri</h4>
        <div class="d-flex gap-2 align-items-center">
            <a asp-controller="Home" asp-action="ExportMembersExcel" class="btn btn-sm btn-success d-flex align-items-center gap-1">
                <i class="bi bi-file-earmark-excel-fill"></i> Excel
            </a>
            <a asp-controller="Home" asp-action="ExportMembersPdf" class="btn btn-sm btn-danger d-flex align-items-center gap-1">
                <i class="bi bi-file-earmark-pdf-fill"></i> PDF
            </a>
            <a asp-action="Create" class="btn btn-sm btn-discord-primary hover-scale ms-2">
                <i class="bi bi-person-plus-fill me-1"></i> Sunucuya Üye Ekle
            </a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-dark table-hover table-striped border-secondary align-middle">
            <thead>
                <tr>
                    <th>Kullanıcı Adı (E-posta)</th>
                    <th>Sunucu</th>
                    <th>Sunucu Rolü</th>
                    <th>Katılma Tarihi</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var member in Model)
                {
                    <tr>
                        <td class="text-white fw-bold">@member.User?.UserName (@member.User?.Email)</td>
                        <td>@member.Server?.Name</td>
                        <td>
                            <span class="badge @(member.ServerRole == "Owner" ? "bg-warning text-dark" : (member.ServerRole == "Admin" ? "bg-danger" : "bg-primary"))">
                                @member.ServerRole
                            </span>
                        </td>
                        <td>@member.JoinedDate.ToLocalTime().ToString("g")</td>
                        <td>
                            <a asp-action="Delete" asp-route-serverId="@member.ServerId" asp-route-userId="@member.UserId" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-person-dash-fill"></i> Sunucudan Çıkar
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
