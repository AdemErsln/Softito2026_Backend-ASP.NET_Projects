@model DiscordClone.Models.AppUser

@{
    ViewData["Title"] = "Kullanıcı Düzenle";
}

<div class="card bg-dark text-white border-secondary p-4" style="max-width: 600px;">
    <h4 class="fw-bold text-white mb-4"><i class="bi bi-pencil-square text-warning me-2"></i>Kullanıcı Düzenle</h4>

    <form asp-action="Edit" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label asp-for="UserName" class="form-label">Kullanıcı Adı</label>
            <input asp-for="UserName" class="form-control" required />
            <span asp-validation-for="UserName" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Email" class="form-label">E-posta</label>
            <input asp-for="Email" class="form-control" type="email" required />
            <span asp-validation-for="Email" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Bio" class="form-label">Biyografi</label>
            <textarea asp-for="Bio" class="form-control" rows="3"></textarea>
            <span asp-validation-for="Bio" class="text-danger"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Status" class="form-label">Durum</label>
            <select asp-for="Status" class="form-select">
                <option value="Online">Çevrimiçi (Online)</option>
                <option value="Idle">Boşta (Idle)</option>
                <option value="DoNotDisturb">Rahatsız Etmeyin (Do Not Disturb)</option>
                <option value="Offline">Çevrimdışı (Offline)</option>
            </select>
            <span asp-validation-for="Status" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-warning text-dark fw-bold px-4">Kaydet</button>
            <a asp-action="Index" class="btn btn-outline-light px-4">İptal</a>
        </div>
    </form>
</div>
