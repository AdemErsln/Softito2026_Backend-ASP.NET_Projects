@model DiscordClone.Models.Channel

@{
    ViewData["Title"] = "Kanal Sil";
}

<div class="card bg-dark text-white border-danger p-4" style="max-width: 600px;">
    <h4 class="fw-bold text-danger mb-4"><i class="bi bi-exclamation-triangle-fill me-2"></i>Kanalı Sil</h4>
    
    <p class="text-white">Aşağıdaki kanalı silmek istediğinizden emin misiniz? <strong>(Kanaldaki tüm sohbet geçmişi kalıcı olarak silinecektir!)</strong></p>
    <div class="p-3 bg-black bg-opacity-40 rounded mb-4 text-start">
        <div class="mb-2"><span class="text-muted-discord">Kanal Adı:</span> <strong class="text-white"># @Model.Name</strong></div>
        <div class="mb-2"><span class="text-muted-discord">Tipi:</span> <strong class="text-white">@(Model.Type == ChannelType.Text ? "Metin" : "Ses")</strong></div>
        <div><span class="text-muted-discord">Bağlı Olduğu Sunucu:</span> <strong class="text-white">@Model.Server?.Name</strong></div>
    </div>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-danger px-4">Evet, Sil</button>
            <a asp-action="Index" class="btn btn-outline-light px-4">İptal</a>
        </div>
    </form>
</div>
