@model DiscordClone.Models.Server

@{
    ViewData["Title"] = "Sunucu Düzenle";
}

<div class="card bg-dark text-white border-secondary p-4" style="max-width: 600px;">
    <h4 class="fw-bold text-white mb-4"><i class="bi bi-pencil-square text-warning me-2"></i>Sunucu Düzenle</h4>

    <form asp-action="Edit" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="OwnerId" />

        <div class="mb-3">
            <label asp-for="Name" class="form-label">Sunucu Adı</label>
            <input asp-for="Name" class="form-control" required />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="InvitationCode" class="form-label">Davet Kodu</label>
            <input asp-for="InvitationCode" class="form-control" required />
            <span asp-validation-for="InvitationCode" class="text-danger"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Description" class="form-label">Açıklama</label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-warning text-dark fw-bold px-4">Kaydet</button>
            <a asp-action="Index" class="btn btn-outline-light px-4">İptal</a>
        </div>
    </form>
</div>
