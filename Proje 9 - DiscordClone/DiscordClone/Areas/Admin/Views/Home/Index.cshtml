@model IEnumerable<DiscordClone.Models.Server>

@{
    ViewData["Title"] = "Admin Paneli";
}

<div class="p-2">
    <div class="row mb-4 align-items-center">
        <div class="col">
            <h1 class="text-white fw-bold"><i class="bi bi-shield-fill-check text-warning me-2"></i>Yönetici Kontrol Paneli</h1>
            <p class="text-muted-discord">Sistem durumunu gözlemleyin ve detaylı analiz raporları üretin.</p>
        </div>
        <div class="col-auto d-flex gap-2">
            <a asp-area="Admin" asp-controller="Home" asp-action="ExportExcel" class="btn btn-success d-flex align-items-center gap-2 hover-scale">
                <i class="bi bi-file-earmark-excel-fill"></i> Excel Raporu
            </a>
            <a asp-area="Admin" asp-controller="Home" asp-action="ExportPdf" class="btn btn-danger d-flex align-items-center gap-2 hover-scale">
                <i class="bi bi-file-earmark-pdf-fill"></i> PDF Raporu
            </a>
        </div>
    </div>

    <!-- Statistics Grid -->
    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="discord-card text-center p-4 hover-scale" style="border-left: 4px solid var(--discord-blurple);">
                <i class="bi bi-people-fill text-primary" style="font-size: 2.5rem;"></i>
                <h6 class="text-muted-discord text-uppercase mt-2 font-weight-bold" style="font-size: 0.8rem; letter-spacing: 0.5px;">Toplam Kullanıcı</h6>
                <h2 class="text-white fw-bold mt-1">@ViewBag.UserCount</h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="discord-card text-center p-4 hover-scale" style="border-left: 4px solid var(--discord-success);">
                <i class="bi bi-server text-success" style="font-size: 2.5rem;"></i>
                <h6 class="text-muted-discord text-uppercase mt-2 font-weight-bold" style="font-size: 0.8rem; letter-spacing: 0.5px;">Toplam Sunucu</h6>
                <h2 class="text-white fw-bold mt-1">@ViewBag.ServerCount</h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="discord-card text-center p-4 hover-scale" style="border-left: 4px solid #f39c12;">
                <i class="bi bi-hash text-warning" style="font-size: 2.5rem;"></i>
                <h6 class="text-muted-discord text-uppercase mt-2 font-weight-bold" style="font-size: 0.8rem; letter-spacing: 0.5px;">Toplam Kanal</h6>
                <h2 class="text-white fw-bold mt-1">@ViewBag.ChannelCount</h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="discord-card text-center p-4 hover-scale" style="border-left: 4px solid var(--discord-danger);">
                <i class="bi bi-chat-left-dots-fill text-danger" style="font-size: 2.5rem;"></i>
                <h6 class="text-muted-discord text-uppercase mt-2 font-weight-bold" style="font-size: 0.8rem; letter-spacing: 0.5px;">Toplam Mesaj</h6>
                <h2 class="text-white fw-bold mt-1">@ViewBag.MessageCount</h2>
            </div>
        </div>
    </div>

    <!-- Servers List Table -->
    <div class="row">
        <div class="col-12">
            <div class="discord-card p-4">
                <h4 class="text-white fw-bold mb-4"><i class="bi bi-list-task me-2 text-primary"></i>Aktif Sunucular</h4>
                
                @if (!Model.Any())
                {
                    <p class="text-muted-discord my-4 text-center">Sistemde henüz oluşturulmuş bir sunucu bulunmuyor.</p>
                }
                else
                {
                    <div class="table-responsive">
                        <table class="table table-dark table-hover table-striped border-secondary align-middle">
                            <thead>
                                <tr>
                                    <th>Sunucu Resmi</th>
                                    <th>Sunucu Adı</th>
                                    <th>Davet Kodu</th>
                                    <th>Kurucu / Sahibi</th>
                                    <th>İşlemler</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var server in Model)
                                {
                                    var serverInitials = string.Concat(server.Name.Split(' ').Select(w => w[0])).ToUpper();
                                    if (serverInitials.Length > 2) serverInitials = serverInitials.Substring(0, 2);

                                    <tr>
                                        <td>
                                            @if (!string.IsNullOrEmpty(server.Photo) && server.Photo.StartsWith("/"))
                                            {
                                                <img src="@server.Photo" alt="@server.Name" class="rounded-circle" style="width: 40px; height: 40px; object-fit: cover;" />
                                            }
                                            else
                                            {
                                                <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold" style="width: 40px; height: 40px;">
                                                    @serverInitials
                                                </div>
                                            }
                                        </td>
                                        <td class="text-white fw-bold">@server.Name</td>
                                        <td><code class="text-warning">@server.InvitationCode</code></td>
                                        <td>@server.Owner?.UserName <span class="text-muted small">(@server.Owner?.Email)</span></td>
                                        <td>
                                            <a asp-area="" asp-controller="Chat" asp-action="Index" asp-route-serverId="@server.Id" class="btn btn-sm btn-discord-primary">
                                                Görüntüle
                                            </a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
