@model IEnumerable<DiscordClone.Models.Channel>

@{
    ViewData["Title"] = "Kanal Yönetimi";
}

<div class="card bg-dark text-white border-secondary p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold text-white"><i class="bi bi-hash text-primary me-2"></i>Kanallar</h4>
        <div class="d-flex gap-2 align-items-center">
            <a asp-controller="Home" asp-action="ExportChannelsExcel" class="btn btn-sm btn-success d-flex align-items-center gap-1">
                <i class="bi bi-file-earmark-excel-fill"></i> Excel
            </a>
            <a asp-controller="Home" asp-action="ExportChannelsPdf" class="btn btn-sm btn-danger d-flex align-items-center gap-1">
                <i class="bi bi-file-earmark-pdf-fill"></i> PDF
            </a>
            <a asp-action="Create" class="btn btn-sm btn-discord-primary hover-scale ms-2">
                <i class="bi bi-plus-circle me-1"></i> Yeni Kanal Oluştur
            </a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-dark table-hover table-striped border-secondary align-middle">
            <thead>
                <tr>
                    <th>Kanal Adı</th>
                    <th>Tipi</th>
                    <th>Sunucu</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var channel in Model)
                {
                    <tr>
                        <td class="text-white fw-bold"># @channel.Name</td>
                        <td>
                            <span class="badge @(channel.Type == ChannelType.Text ? "bg-primary" : "bg-info text-dark")">
                                @(channel.Type == ChannelType.Text ? "Metin" : "Ses")
                            </span>
                        </td>
                        <td>@channel.Server?.Name</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@channel.Id" class="btn btn-sm btn-outline-warning me-2">
                                <i class="bi bi-pencil-square"></i> Düzenle
                            </a>
                            <a asp-action="Delete" asp-route-id="@channel.Id" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i> Sil
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
