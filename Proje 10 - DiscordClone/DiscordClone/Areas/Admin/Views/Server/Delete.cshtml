@model DiscordClone.Models.Server

@{
    ViewData["Title"] = "Sunucu Sil";
}

<div class="card bg-dark text-white border-danger p-4" style="max-width: 600px;">
    <h4 class="fw-bold text-danger mb-4"><i class="bi bi-exclamation-triangle-fill me-2"></i>Sunucuyu Sil</h4>
    
    <p class="text-white">Aşağıdaki sunucuyu silmek istediğinizden emin misiniz? <strong>(Tüm kanalları ve ilişkili mesajları da kalıcı olarak silinecektir!)</strong></p>
    <div class="p-3 bg-black bg-opacity-40 rounded mb-4 text-start">
        <div class="mb-2"><span class="text-muted-discord">Sunucu Adı:</span> <strong class="text-white">@Model.Name</strong></div>
        <div class="mb-2"><span class="text-muted-discord">Davet Kodu:</span> <strong class="text-white">@Model.InvitationCode</strong></div>
        <div class="mb-2"><span class="text-muted-discord">Kurucu:</span> <strong class="text-white">@Model.Owner?.UserName</strong></div>
        <div><span class="text-muted-discord">Açıklama:</span> <span class="text-muted-discord">@Model.Description</span></div>
    </div>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-danger px-4">Evet, Sil</button>
            <a asp-action="Index" class="btn btn-outline-light px-4">İptal</a>
        </div>
    </form>
</div>
