@model IEnumerable<DiscordClone.Models.Server>

@{
    ViewData["Title"] = "Sunucu Yönetimi";
}

<div class="card bg-dark text-white border-secondary p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold text-white"><i class="bi bi-server text-success me-2"></i>Sunucular</h4>
        <div class="d-flex gap-2">
            <a asp-controller="Home" asp-action="ExportExcel" class="btn btn-sm btn-success d-flex align-items-center gap-1">
                <i class="bi bi-file-earmark-excel-fill"></i> Excel
            </a>
            <a asp-controller="Home" asp-action="ExportPdf" class="btn btn-sm btn-danger d-flex align-items-center gap-1">
                <i class="bi bi-file-earmark-pdf-fill"></i> PDF
            </a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-dark table-hover table-striped border-secondary align-middle">
            <thead>
                <tr>
                    <th>Görsel</th>
                    <th>Sunucu Adı</th>
                    <th>Davet Kodu</th>
                    <th>Açıklama</th>
                    <th>Sahibi (Owner)</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var server in Model)
                {
                    var initials = string.Concat(server.Name.Split(' ').Select(w => w[0])).ToUpper();
                    if (initials.Length > 2) initials = initials.Substring(0, 2);

                    <tr>
                        <td>
                            @if (!string.IsNullOrEmpty(server.Photo) && server.Photo.StartsWith("/"))
                            {
                                <img src="@server.Photo" alt="@server.Name" class="rounded-circle" style="width: 40px; height: 40px; object-fit: cover;" />
                            }
                            else
                            {
                                <div class="rounded-circle bg-primary text-white d-flex align-items-center justify-content-center fw-bold" style="width: 40px; height: 40px;">
                                    @initials
                                </div>
                            }
                        </td>
                        <td class="text-white fw-bold">@server.Name</td>
                        <td><code class="text-warning">@server.InvitationCode</code></td>
                        <td class="text-truncate" style="max-width: 200px;">@server.Description</td>
                        <td>@server.Owner?.UserName</td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@server.Id" class="btn btn-sm btn-outline-warning me-2">
                                <i class="bi bi-pencil-square"></i> Düzenle
                            </a>
                            <a asp-action="Delete" asp-route-id="@server.Id" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i> Sil
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
