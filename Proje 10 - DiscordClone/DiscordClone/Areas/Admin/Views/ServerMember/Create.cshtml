@model DiscordClone.Models.ServerMember

@{
    ViewData["Title"] = "Sunucuya Üye Ata";
}

<div class="card bg-dark text-white border-secondary p-4" style="max-width: 600px;">
    <h4 class="fw-bold text-white mb-4"><i class="bi bi-person-plus-fill text-primary me-2"></i>Sunucuya Üye Ekle</h4>

    <form asp-action="Create" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="ServerId" class="form-label">Sunucu</label>
            <select asp-for="ServerId" asp-items="ViewBag.ServerList" class="form-select" required>
                <option disabled selected>-- Sunucu Seçin --</option>
            </select>
            <span asp-validation-for="ServerId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="UserId" class="form-label">Kullanıcı</label>
            <select asp-for="UserId" asp-items="ViewBag.UserList" class="form-select" required>
                <option disabled selected>-- Kullanıcı Seçin --</option>
            </select>
            <span asp-validation-for="UserId" class="text-danger"></span>
        </div>

        <div class="mb-4">
            <label asp-for="ServerRole" class="form-label">Sunucu İçi Rol</label>
            <select asp-for="ServerRole" class="form-select" required>
                <option value="Member">Üye (Member)</option>
                <option value="Admin">Sunucu Yöneticisi (Admin)</option>
                <option value="Owner">Kurucu (Owner)</option>
            </select>
            <span asp-validation-for="ServerRole" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-discord-primary px-4">Ata / Ekle</button>
            <a asp-action="Index" class="btn btn-outline-light px-4">İptal</a>
        </div>
    </form>
</div>
