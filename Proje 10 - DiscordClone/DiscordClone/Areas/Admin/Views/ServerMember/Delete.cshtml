@model DiscordClone.Models.ServerMember

@{
    ViewData["Title"] = "Üye Sunucudan Çıkar";
}

<div class="card bg-dark text-white border-danger p-4" style="max-width: 600px;">
    <h4 class="fw-bold text-danger mb-4"><i class="bi bi-exclamation-triangle-fill me-2"></i>Üyeyi Sunucudan Çıkar</h4>
    
    <p class="text-white">Aşağıdaki üyeyi sunucudan çıkarmak (kick) istediğinizden emin misiniz?</p>
    <div class="p-3 bg-black bg-opacity-40 rounded mb-4 text-start">
        <div class="mb-2"><span class="text-muted-discord">Kullanıcı:</span> <strong class="text-white">@Model.User?.UserName (@Model.User?.Email)</strong></div>
        <div class="mb-2"><span class="text-muted-discord">Sunucu:</span> <strong class="text-white">@Model.Server?.Name</strong></div>
        <div class="mb-2"><span class="text-muted-discord">Rol:</span> <strong class="text-white">@Model.ServerRole</strong></div>
        <div><span class="text-muted-discord">Katılma Tarihi:</span> <strong class="text-white">@Model.JoinedDate.ToLocalTime().ToString("g")</strong></div>
    </div>

    <form asp-action="Delete" method="post">
        <input type="hidden" name="serverId" value="@Model.ServerId" />
        <input type="hidden" name="userId" value="@Model.UserId" />
        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-danger px-4">Evet, Çıkar</button>
            <a asp-action="Index" class="btn btn-outline-light px-4">İptal</a>
        </div>
    </form>
</div>
