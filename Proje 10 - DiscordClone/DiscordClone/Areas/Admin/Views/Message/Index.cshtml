@model IEnumerable<DiscordClone.Models.Message>

@{
    ViewData["Title"] = "Mesaj Yönetimi";
}

<div class="card bg-dark text-white border-secondary p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold text-white"><i class="bi bi-chat-left-text text-primary me-2"></i>Mesajlar</h4>
        <div class="d-flex gap-2">
            <a asp-controller="Home" asp-action="ExportMessagesExcel" class="btn btn-sm btn-success d-flex align-items-center gap-1">
                <i class="bi bi-file-earmark-excel-fill"></i> Excel
            </a>
            <a asp-controller="Home" asp-action="ExportMessagesPdf" class="btn btn-sm btn-danger d-flex align-items-center gap-1">
                <i class="bi bi-file-earmark-pdf-fill"></i> PDF
            </a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-dark table-hover table-striped border-secondary align-middle">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Gönderen</th>
                    <th>Sunucu / Kanal</th>
                    <th>Mesaj İçeriği</th>
                    <th>Tarih</th>
                    <th>İşlemler</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var msg in Model)
                {
                    <tr>
                        <td>@msg.Id</td>
                        <td class="text-white fw-bold">@msg.Sender?.UserName</td>
                        <td>
                            @msg.Channel?.Server?.Name <span class="text-muted-discord">/</span> #@msg.Channel?.Name
                        </td>
                        <td class="text-truncate" style="max-width: 300px;">@msg.Content</td>
                        <td>@msg.SendDate.ToLocalTime().ToString("g")</td>
                        <td>
                            <a asp-action="Delete" asp-route-id="@msg.Id" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash"></i> Sil
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
