@model DiscordClone.Models.LoginVM

@{
    ViewData["Title"] = "Giriş Yap";
}

<div class="container py-5">
    <div class="row justify-content-center align-items-center" style="min-height: 70vh;">
        <div class="col-md-5">
            <div class="discord-card hover-scale">
                <div class="text-center mb-4">
                    <h3 class="card-title-discord mb-2">Tekrar hoş geldin!</h3>
                    <p class="text-muted-discord">Seni tekrar görmek harika!</p>
                </div>

                <!-- Seeder Credentials Info Alert for development testing -->
                <div class="alert alert-warning border-0 bg-warning bg-opacity-10 text-warning rounded p-3 mb-4 small text-start">
                    <div class="fw-bold mb-1"><i class="bi bi-info-circle-fill me-2"></i>Test Yönetici Bilgileri:</div>
                    <div class="mb-1"><span class="text-muted-discord">E-posta:</span> <strong>admin@disaccord.com</strong></div>
                    <div><span class="text-muted-discord">Şifre:</span> <strong>Admin123!</strong></div>
                </div>

                <form asp-controller="Account" asp-action="Login" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" placeholder="admin@disaccord.com veya e-posta girin" required />
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label"></label>
                        <input asp-for="Password" class="form-control" type="password" placeholder="Şifrenizi girin" required />
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>

                    <div class="mb-4 d-flex justify-content-between align-items-center">
                        <div class="form-check">
                            <input asp-for="RememberMe" class="form-check-input bg-dark border-secondary" />
                            <label asp-for="RememberMe" class="form-check-label text-muted-discord small text-transform-none" style="text-transform: none; letter-spacing: 0;"></label>
                        </div>
                    </div>

                    <button type="submit" class="btn btn-discord-primary w-100 py-2.5 fs-6 mb-3">Giriş Yap</button>

                    <div class="text-center mt-3">
                        <span class="text-muted-discord small">Hesaba mı ihtiyacın var? </span>
                        <a asp-controller="Account" asp-action="Register" class="link-discord small fw-bold">Kaydol</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
