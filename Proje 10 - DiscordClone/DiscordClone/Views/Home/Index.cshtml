@{
    ViewData["Title"] = "Macera Dolu Bir Yer...";
}

<!-- Hero Section with Discord Theme -->
<div class="container-fluid px-0" style="background: linear-gradient(135deg, #404eed 0%, #2b2d31 100%); min-height: 85vh; display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden;">
    <!-- Background vector accents using CSS circles -->
    <div class="position-absolute bg-primary bg-opacity-20 rounded-circle" style="width: 600px; height: 600px; top: -10%; left: -10%; filter: blur(80px);"></div>
    <div class="position-absolute bg-danger bg-opacity-10 rounded-circle" style="width: 500px; height: 500px; bottom: -10%; right: -5%; filter: blur(100px);"></div>

    <div class="container text-center py-5 position-relative" style="z-index: 10;">
        <div class="row justify-content-center">
            <div class="col-lg-9">
                <!-- Glowing Logo Emblem -->
                <div class="d-inline-flex align-items-center justify-content-center bg-white bg-opacity-10 rounded-circle p-3 mb-4" style="backdrop-filter: blur(10px);">
                    <i class="bi bi-discord text-white" style="font-size: 4rem; filter: drop-shadow(0 0 15px rgba(255, 255, 255, 0.4));"></i>
                </div>

                <h1 class="display-2 fw-black text-white mb-4 tracking-tight" style="font-weight: 800; font-family: 'Plus Jakarta Sans', sans-serif;">BİR YER HAYAL EDİN...</h1>
                <p class="fs-4 text-white text-opacity-80 mb-5 px-lg-5 fw-light" style="line-height: 1.6;">
                    ...okul kulübünün, oyun grubunun ya da dünya genelinde bir sanat topluluğunun parçası olabileceğiniz bir yer. Sadece sizin ve birkaç arkadaşınızın birlikte zaman geçirebileceği güvenli, davet usulü bir alan.
                </p>

                <div class="d-flex flex-wrap justify-content-center gap-3">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <a class="btn btn-lg btn-light text-dark px-5 py-3 fs-5 fw-bold hover-scale shadow" asp-controller="Chat" asp-action="Index">
                            <i class="bi bi-chat-left-text-fill me-2 text-primary"></i>Sohbete Başla
                        </a>
                        @if (User.IsInRole("Admin"))
                        {
                            <a class="btn btn-lg btn-warning px-5 py-3 fs-5 text-dark fw-bold hover-scale shadow" asp-area="Admin" asp-controller="Home" asp-action="Index">
                                <i class="bi bi-shield-fill-check me-2"></i>Yönetici Paneli
                            </a>
                        }
                    }
                    else
                    {
                        <a class="btn btn-lg btn-light text-dark px-4 py-3 fs-5 fw-bold hover-scale shadow" asp-controller="Account" asp-action="Register">
                            Hesap Oluştur
                        </a>
                        <a class="btn btn-lg btn-outline-light px-4 py-3 fs-5 hover-scale" asp-controller="Account" asp-action="Login">
                            Giriş Yap
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Features Section -->
<div class="container py-5 my-5">
    <div class="row align-items-center g-5 py-4">
        <div class="col-md-6">
            <div class="discord-card p-5 shadow-lg border border-secondary border-opacity-25 bg-opacity-70">
                <div class="bg-primary bg-opacity-10 p-3 rounded d-inline-block text-primary mb-3">
                    <i class="bi bi-hash fs-3"></i>
                </div>
                <h3 class="text-white fw-bold mb-3">Konuların Kolayca Bölündüğü Odalar</h3>
                <p class="text-muted-discord">
                    Sunuculardaki metin kanalları, sohbetlerinizi konulara göre düzenlemenizi sağlar. Grup sohbetlerini kalabalıklaştırmadan okul projelerini planlayabilir, oyun taktiklerini konuşabilirsiniz.
                </p>
            </div>
        </div>
        <div class="col-md-6">
            <div class="discord-card p-5 shadow-lg border border-secondary border-opacity-25 bg-opacity-70">
                <div class="bg-success bg-opacity-10 p-3 rounded d-inline-block text-success mb-3">
                    <i class="bi bi-people-fill fs-3"></i>
                </div>
                <h3 class="text-white fw-bold mb-3">Üyeler ve Davet Kodları</h3>
                <p class="text-muted-discord">
                    Kendi topluluğunuzu benzersiz davet kodlarıyla genişletin. Sunucuya giren herkesi üye panelinde görün, durumlarını gözlemleyin ve roller atayarak yetkilendirin.
                </p>
            </div>
        </div>
    </div>
</div>
