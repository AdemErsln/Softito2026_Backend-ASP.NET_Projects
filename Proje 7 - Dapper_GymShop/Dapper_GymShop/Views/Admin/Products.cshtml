@model IEnumerable<Product>
@{
    ViewData["Title"] = "Ürün Yönetimi";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="space-y-8">
    <div class="flex justify-between items-center">
        <div>
            <h2 class="text-2xl font-black tracking-tight">📦 Vitrin ve Ürün Yönetimi</h2>
            <p class="text-xs theme-text-muted mt-1">Sitede sergilenen ürünleri listeleyin, güncelleyin veya kaldırın.</p>
        </div>
        <div class="flex gap-2">
            <a href="/Admin/ExportProductsToExcel" class="px-4 py-2.5 rounded-xl text-xs font-bold bg-emerald-600 hover:bg-emerald-700 text-white transition cursor-pointer shadow-md" style="text-decoration: none; display: inline-flex; align-items: center;">
                📊 Excel Çıktısı
            </a>
            <a href="/Admin/ExportProductsToPdf" class="px-4 py-2.5 rounded-xl text-xs font-bold bg-rose-600 hover:bg-rose-700 text-white transition cursor-pointer shadow-md" style="text-decoration: none; display: inline-flex; align-items: center;">
                📄 PDF Raporu
            </a>
            <button onclick="toggleModal('addProductModal')" class="px-4 py-2.5 rounded-xl text-xs font-bold theme-btn-primary transition cursor-pointer shadow-md">
                ➕ Yeni Ürün Ekle
            </button>
        </div>
    </div>

    <div class="theme-card rounded-2xl border shadow-xs overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="border-b theme-border text-xs font-bold uppercase">
                        <th class="px-6 py-4 theme-th">Görsel</th>
                        <th class="px-6 py-4 theme-th">Ürün Adı</th>
                        <th class="px-6 py-4 theme-th">Fiyat</th>
                        <th class="px-6 py-4 theme-th text-center">Stok Durumu</th>
                        <th class="px-6 py-4 text-right theme-th">İşlemler</th>
                    </tr>
                </thead>
                <tbody class="divide-y theme-border text-sm">
                    @if (Model != null && Model.Any())
                    {
                        foreach (var product in Model)
                        {
                            <tr class="hover:opacity-95 transition">
                                <td class="px-6 py-3.5">
                                    <div class="w-12 h-12 rounded-xl theme-border border flex items-center justify-center font-bold" style="background-color: var(--bg-main)">🏋️‍♂️</div>
                                </td>
                                <td class="px-6 py-3.5 font-bold">@product.ProductName</td>
                                <td class="px-6 py-3.5 font-semibold">@product.Price.ToString("C2")</td>
                                <td class="px-6 py-3.5 text-center">
                                    @if (product.Stock > 10)
                                    {
                                        <span class="px-2.5 py-1 rounded-lg text-xs font-bold bg-emerald-500/10 text-emerald-500">@product.Stock Adet</span>
                                    }
                                    else if (product.Stock > 0)
                                    {
                                        <span class="px-2.5 py-1 rounded-lg text-xs font-bold bg-amber-500/10 text-amber-500">Kritik: @product.Stock</span>
                                    }
                                    else
                                    {
                                        <span class="px-2.5 py-1 rounded-lg text-xs font-bold bg-rose-500/10 text-rose-500">Tükendi</span>
                                    }
                                </td>
                                <td class="px-6 py-3.5 text-right space-x-1">
                                    <button onclick="toggleModal('editModal-@product.ID')" class="p-2 border theme-border rounded-xl text-xs hover:bg-slate-500/10 cursor-pointer" title="Düzenle">⚙️</button>
                                    <a href="/Admin/DeleteProduct/@product.ID" onclick="return confirm('Bu ürünü silmek istediğinize emin misiniz?')" class="p-2 text-rose-500 hover:bg-rose-500/10 rounded-xl text-xs inline-block transition" title="Sil">🗑️</a>
                                </td>
                            </tr>

                            <div id="editModal-@product.ID" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50 p-4 backdrop-blur-xs">
                                <div class="theme-card border p-6 rounded-2xl shadow-xl max-w-md w-full space-y-4" style="background-color: var(--bg-card)">
                                    <div class="flex justify-between items-center border-b theme-border pb-3">
                                        <h3 class="text-base font-bold">Ürün Verilerini Düzenle</h3>
                                        <button onclick="toggleModal('editModal-@product.ID')" class="text-xl font-bold cursor-pointer">&times;</button>
                                    </div>
                                    <form action="/Admin/UpdateProduct" method="POST" class="space-y-3">
                                        <input type="hidden" name="ID" value="@product.ID" />
                                        <div>
                                            <label class="text-xs font-bold block mb-1">Ürün Adı</label>
                                            <input type="text" name="ProductName" value="@product.ProductName" class="w-full p-2.5 rounded-xl border theme-border bg-transparent text-sm outline-none" required />
                                        </div>
                                        <div class="grid grid-cols-2 gap-3">
                                            <div>
                                                <label class="text-xs font-bold block mb-1">Fiyat (TL)</label>
                                                <input type="number" step="0.01" name="Price" value="@product.Price.ToString("F2").Replace(",", ".")" class="w-full p-2.5 rounded-xl border theme-border bg-transparent text-sm outline-none" required />
                                            </div>
                                            <div>
                                                <label class="text-xs font-bold block mb-1">Stok Adedi</label>
                                                <input type="number" name="Stock" value="@product.Stock" class="w-full p-2.5 rounded-xl border theme-border bg-transparent text-sm outline-none" required />
                                            </div>
                                        </div>
                                        <div>
                                            <label class="text-xs font-bold block mb-1">Görsel Yolu</label>
                                            <input type="text" name="ImageURL" value="@product.ImageURL" class="w-full p-2.5 rounded-xl border theme-border bg-transparent text-sm outline-none" />
                                        </div>
                                        <div class="flex justify-end gap-2 pt-2">
                                            <button type="button" onclick="toggleModal('editModal-@product.ID')" class="px-4 py-2 border theme-border text-xs rounded-xl cursor-pointer">Vazgeç</button>
                                            <button type="submit" class="px-4 py-2 text-xs font-bold theme-btn-primary rounded-xl cursor-pointer">Değişiklikleri Kaydet</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="px-6 py-8 text-center theme-text-muted">Kayıtlı ürün bulunamadı.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div id="addProductModal" class="fixed inset-0 bg-black/50 hidden items-center justify-center z-50 p-4 backdrop-blur-xs">
    <div class="theme-card border p-6 rounded-2xl shadow-xl max-w-md w-full space-y-4" style="background-color: var(--bg-card)">
        <div class="flex justify-between items-center border-b theme-border pb-3">
            <h3 class="text-base font-bold">Yeni Ürün Girişi Yap</h3>
            <button onclick="toggleModal('addProductModal')" class="text-xl font-bold cursor-pointer">&times;</button>
        </div>
        <form action="/Admin/AddProduct" method="POST" class="space-y-3">
            <div>
                <label class="text-xs font-bold block mb-1">Ürün Adı</label>
                <input type="text" name="ProductName" placeholder="Örn: Gold Shaker" class="w-full p-2.5 rounded-xl border theme-border bg-transparent text-sm outline-none" required />
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div>
                    <label class="text-xs font-bold block mb-1">Fiyat (TL)</label>
                    <input type="number" step="0.01" name="Price" placeholder="450.00" class="w-full p-2.5 rounded-xl border theme-border bg-transparent text-sm outline-none" required />
                </div>
                <div>
                    <label class="text-xs font-bold block mb-1">Stok Adedi</label>
                    <input type="number" name="Stock" placeholder="50" class="w-full p-2.5 rounded-xl border theme-border bg-transparent text-sm outline-none" required />
                </div>
            </div>
            <div>
                <label class="text-xs font-bold block mb-1">Görsel Dosya Yolu</label>
                <input type="text" name="ImageURL" placeholder="images/shaker.png" class="w-full p-2.5 rounded-xl border theme-border bg-transparent text-sm outline-none" />
            </div>
            <div class="flex justify-end gap-2 pt-2">
                <button type="button" onclick="toggleModal('addProductModal')" class="px-4 py-2 border theme-border text-xs rounded-xl cursor-pointer">Kapat</button>
                <button type="submit" class="px-4 py-2 text-xs font-bold theme-btn-primary rounded-xl cursor-pointer">Vitrini Güncelle (Ekle)</button>
            </div>
        </form>
    </div>
</div>

<script>
    function toggleModal(id) {
        const el = document.getElementById(id);
        el.classList.contains('hidden') ? (el.classList.remove('hidden'), el.classList.add('flex')) : (el.classList.remove('flex'), el.classList.add('hidden'));
    }
</script>