@model RentacCar.Model.Kiralama
@{
    ViewData["Title"] = "Sözleşmeyi Güncelle";
}
<div class="row justify-content-center">
    <div class="col-lg-10">
        <div class="d-flex justify-content-between align-items-center flex-wrap mb-4">
            <div>
                <h3 class="text-primary fw-bold mb-1">Sözleşme Revizyonu</h3>
                <p class="text-muted mb-0"><span class="text-primary fw-bold">#RNT-@Model.RentalId</span> numaralı kontrat üzerinde değişiklik yapıyorsunuz.</p>
            </div>
            <div>
                <a href="/Kiralama/Index" class="btn btn-soft-secondary rounded-pill px-4">Kapat</a>
            </div>
        </div>

        <div class="card shadow-sm">
            <div class="card-header border-bottom py-3 bg-soft-warning">
                <h4 class="card-title fw-bold text-warning mb-0">Sözleşme Güncelleme Formu</h4>
            </div>
            <div class="card-body p-4">
                <form action="/Kiralama/Edit/@Model.RentalId" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="RentalId" />

                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label class="form-label fw-bold text-secondary">Müşteri</label>
                            <select asp-for="CustomerId" class="form-select   fw-bold" asp-items="ViewBag.Musteriler" required></select>
                        </div>
                        <div class="col-md-6 mb-4">
                            <label class="form-label fw-bold text-secondary">Araç</label>
                            <select asp-for="CarId" class="form-select   fw-bold" asp-items="ViewBag.Araclar" required></select>
                        </div>
                        <div class="col-md-6 mb-4">
                            <label class="form-label fw-bold text-secondary">Alış Tarihi</label>
                            <input type="date" asp-for="AlisTarihi" class="form-control  " required />
                        </div>
                        <div class="col-md-6 mb-4">
                            <label class="form-label fw-bold text-secondary">İade Tarihi</label>
                            <input type="date" asp-for="IadeTarihi" class="form-control  " required />
                        </div>
                        <div class="col-md-6 mb-4">
                            <label class="form-label fw-bold text-secondary">Toplam Tutar</label>
                            <div class="input-group">
                                <span class="input-group-text bg-soft-success text-success fw-bold">₺</span>
                                <input type="number" step="0.01" asp-for="ToplamTutar" class="form-control fs-5 fw-bold text-success" required />
                            </div>
                        </div>
                        <div class="col-md-6 mb-4">
                            <label class="form-label fw-bold text-secondary">Sözleşme Durumu</label>
                            <select asp-for="Durum" class="form-select fw-bold">
                                <option value="Aktif">Aktif (Araç Kirada)</option>
                                <option value="Kapatıldı">Kapatıldı (Araç İade Alındı - Boşa Çıktı)</option>
                            </select>
                        </div>
                    </div>

                    <hr class="hr-horizontal my-3">
                    <div class="d-flex justify-content-end">
                        <button type="submit" class="btn btn-warning text-white rounded-pill px-5">Sözleşmeyi Güncelle / Kapat</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>