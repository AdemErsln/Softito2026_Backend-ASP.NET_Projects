@model IEnumerable<RentACar.Models.Araclars>
@{
    ViewData["Title"] = "Araç Filosu Yönetimi";
}

<div class="row">
    <div class="col-lg-12">
        
        <!-- ÜST BAŞLIK VE EKLEME BUTONU ALANI -->
        <div class="d-flex justify-content-between align-items-center flex-wrap mb-4">
            <div>
                <h3 class="text-primary fw-bold mb-1">Araç Filosu</h3>
                <p class="text-muted mb-0">Sistemde kayıtlı tüm araçların listesi, günlük ücretleri ve anlık durumları.</p>
            </div>
            <div>
                <!-- Şablonun orijinal ana buton stili -->
                <a href="/Arac/Create" class="btn btn-primary d-flex align-items-center gap-2">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="me-1">
                        <path d="M12 4V20M4 12H20" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    Yeni Araç Ekle
                </a>
            </div>
        </div>

        <!-- ARAMA VE ÇIKTI BUTONLARI ALANI -->
        <div class="row mb-4 g-3 align-items-center">
            <div class="col-md-6">
                <form method="get" asp-action="Index" class="d-flex gap-2">
                    <input type="text" name="searchString" class="form-control" placeholder="Plaka, marka veya model ile ara..." value="@ViewBag.SearchString" />
                    <button type="submit" class="btn btn-primary">Ara</button>
                    @if (!string.IsNullOrEmpty(ViewBag.SearchString))
                    {
                        <a asp-action="Index" class="btn btn-outline-secondary">Temizle</a>
                    }
                </form>
            </div>
            <div class="col-md-6 text-md-end">
                <a asp-action="ExportToExcel" class="btn btn-success me-2">
                    Excel Çıktısı
                </a>
                <a asp-action="ExportToPdf" class="btn btn-danger">
                    PDF Çıktısı
                </a>
            </div>
        </div>

        <!-- TABLO KARTI -->
        <div class="card card-block card-stretch custom-scroll">
            <div class="card-body p-0">
                <div class="table-responsive rounded">
                    <table class="table table-striped mb-0">
                        <thead class="bg-soft-primary text-primary">
                            <tr>
                                <th class="ps-4">Plaka</th>
                                <th>Marka</th>
                                <th>Model</th>
                                <th>Model Yılı</th>
                                <th>Günlük Ücret</th>
                                <th>Durum</th>
                                <th class="text-end pe-4">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var arac in Model)
                                {
                                    <tr class="white-space-no-wrap align-middle">
                                        <!-- Plaka alanı şablon stilinde belirgin -->
                                        <td class="ps-4">
                                            <span class="badge bg-dark fs-6 font-monospace px-2 py-1 text-white border border-secondary shadow-sm">
                                                @arac.Plaka
                                            </span>
                                        </td>
                                        <td class="fw-bold text-secondary">@arac.Marka</td>
                                        <td>@arac.Model</td>
                                        <td>@arac.Yil</td>
                                        <td class="text-success fw-bold">@arac.GunlukUcret.ToString("C2")</td>
                                        <td>
                                            <!-- Duruma göre Nairobi Şablonu Badge Renkleri -->
                                            @if (arac.Durum == "Müsait")
                                            {
                                                <span class="badge bg-soft-success text-success rounded-pill px-3 py-2">Müsait</span>
                                            }
                                            else if (arac.Durum == "Kirada")
                                            {
                                                <span class="badge bg-soft-primary text-primary rounded-pill px-3 py-2">Kirada</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-soft-danger text-danger rounded-pill px-3 py-2">@arac.Durum</span>
                                            }
                                        </td>
                                        <!-- İşlem Butonları (Soft Renk Temalı) -->
                                        <td class="text-end pe-4">
                                            <div class="d-inline-flex gap-2">
                                                <a href="/Arac/Edit/@arac.CarId" class="btn btn-sm btn-soft-warning rounded-pill px-3" title="Düzenle">
                                                    Düzenle
                                                </a>
                                                <a href="/Arac/Delete/@arac.CarId" class="btn btn-sm btn-soft-danger rounded-pill px-3" 
                                                   onclick="return confirm('@arac.Plaka plakalı aracı silmek istediğinize emin misiniz?')" title="Sil">
                                                    Sil
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center py-5 text-muted">
                                        <div class="mb-2">
                                            <svg width="40" height="40" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                            </svg>
                                        </div>
                                        <span>Sistemde kayıtlı araç bulunamadı.</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
</div>