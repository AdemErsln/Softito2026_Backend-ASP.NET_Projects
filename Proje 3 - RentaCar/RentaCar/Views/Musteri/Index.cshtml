@model IEnumerable<RentacCar.Model.Kullanicilar>
@{
    ViewData["Title"] = "Müşteri Yönetimi";
}

<div class="row">
    <div class="col-lg-12">
        
        <!-- ÜST BAŞLIK VE EKLEME BUTONU ALANI -->
        <div class="d-flex justify-content-between align-items-center flex-wrap mb-4">
            <div>
                <h3 class="text-primary fw-bold mb-1">Müşteri Kayıtları</h3>
                <p class="text-muted mb-0">Sistemde kayıtlı olan tüm kiracıların ve kullanıcıların bilgileri.</p>
            </div>
            <div>
                <a href="/Kullanici/Create" class="btn btn-primary d-flex align-items-center gap-2">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="me-1">
                        <path d="M12 4V20M4 12H20" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                    Yeni Müşteri Ekle
                </a>
            </div>
        </div>

        <!-- TABLO KARTI -->
        <div class="card card-block card-stretch custom-scroll">
            <div class="card-body p-0">
                <div class="table-responsive rounded">
                    <table class="table table-striped mb-0">
                        <thead class="bg-soft-primary text-primary">
                            <tr>
                                <th class="ps-4">Müşteri ID</th>
                                <th>Ad Soyad</th>
                                <th>Yaş</th>
                                <th>Telefon Numarası</th>
                                <th class="text-end table-actions pe-4">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var musteri in Model)
                                {
                                    <tr class="white-space-no-wrap align-middle">
                                        <td class="ps-4 text-muted font-monospace">#@musteri.Id</td>
                                        <td>
                                            <span class="fw-bold text-secondary">@musteri.AdSoyad</span>
                                        </td>
                                        <td>
                                            <span class="badge bg-soft-secondary text-dark rounded-pill px-3 py-1">@musteri.yas Yaş</span>
                                        </td>
                                        <td>
                                            <span class="text-dark">@musteri.Telefon</span>
                                        </td>
                                        <!-- İşlem Butonları -->
                                        <td class="text-end pe-4">
                                            <div class="d-inline-flex gap-2">
                                                <a href="/Kullanici/Edit/@musteri.Id" class="btn btn-sm btn-soft-warning rounded-pill px-3" title="Düzenle">
                                                    Düzenle
                                                </a>
                                                <a href="/Kullanici/Delete/@musteri.Id" class="btn btn-sm btn-soft-danger rounded-pill px-3" 
                                                   onclick="return confirm('@musteri.AdSoyad isimli müşteriyi silmek istediğinize emin misiniz?')" title="Sil">
                                                    Sil
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-5 text-muted">
                                        <div class="mb-2">
                                            <svg width="40" height="40" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                                            </svg>
                                        </div>
                                        <span>Sistemde kayıtlı müşteri bulunamadı.</span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
</div>