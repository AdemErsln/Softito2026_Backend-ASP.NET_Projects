@{
    ViewData["Title"] = "Yönetim Paneli";
}

<!-- HOŞ GELDİNİZ VE BAŞLIK ALANI -->
<div class="row mb-4">
    <div class="col-md-12">
        <h2 class="text-primary fw-bold mb-1">Hoş Geldiniz, Yönetici</h2>
        <p class="text-muted">Rent A Car sisteminizin anlık durum raporu ve analitiği aşağıdadır.</p>
    </div>
</div>

<!-- ANALİTİK RAPORLAMA KARTLARI (3-4 ADET) -->
<div class="row">
    
    <!-- 1. KART: TOPLAM ARAÇ -->
    <div class="col-md-6 col-lg-3 mb-4">
        <div class="card bg-soft-primary shadow-none border-0 m-0" style="min-height: 130px;">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="text-primary fw-bold mb-2">Toplam Araç</h6>
                    <h2 class="fw-bold   mb-0 font-monospace">@ViewBag.ToplamArac</h2>
                    <small class="text-muted">Filodaki Tüm Araçlar</small>
                </div>
                <div class="bg-primary text-white rounded p-3 d-flex align-items-center justify-content-center" style="width: 55px; height: 50px;">
                    <!-- Araç / Garaj İkonu -->
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M5 18H19M4 10V14M20 10V14M12 5L3 10H21L12 5ZM6 14H18M9 14V18M15 14V18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
            </div>
        </div>
    </div>

    <!-- 2. KART: KİRADAKİ ARAÇLAR -->
    <div class="col-md-6 col-lg-3 mb-4">
        <div class="card bg-soft-warning shadow-none border-0 m-0" style="min-height: 130px;">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="text-warning fw-bold mb-2">Kiradaki Araçlar</h6>
                    <h2 class="fw-bold   mb-0 font-monospace">@ViewBag.KiradakiArac</h2>
                    <small class="text-muted">Aktif Sözleşmeler</small>
                </div>
                <div class="bg-warning text-white rounded p-3 d-flex align-items-center justify-content-center" style="width: 55px; height: 50px;">
                    <!-- Anahtar / Kiralama İkonu -->
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M15 6C16.6569 6 18 4.65685 18 3C18 1.34315 16.6569 0 15 0C13.3431 0 12 1.34315 12 3C12 4.65685 13.3431 6 15 6ZM15 6V24M15 15H9M15 19H6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
            </div>
        </div>
    </div>

    <!-- 3. KART: TOPLAM MÜŞTERİ -->
    <div class="col-md-6 col-lg-3 mb-4">
        <div class="card bg-soft-danger shadow-none border-0 m-0" style="min-height: 130px;">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="text-danger fw-bold mb-2">Toplam Müşteri</h6>
                    <h2 class="fw-bold   mb-0 font-monospace">@ViewBag.ToplamMusteri</h2>
                    <small class="text-muted">Kayıtlı Sürücüler</small>
                </div>
                <div class="bg-danger text-white rounded p-3 d-flex align-items-center justify-content-center" style="width: 55px; height: 50px;">
                    <!-- Kullanıcı İkonu -->
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                </div>
            </div>
        </div>
    </div>

    <!-- 4. KART: TOPLAM CİRO -->
    <div class="col-md-6 col-lg-3 mb-4">
        <div class="card bg-soft-success shadow-none border-0 m-0" style="min-height: 130px;">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="text-success fw-bold mb-2">Toplam Ciro</h6>
                    <h3 class="fw-bold   mb-0 font-monospace">@(((decimal)ViewBag.ToplamCiro).ToString("C0"))</h3>
                    <small class="text-muted">Kazanılan Toplam Gelir</small>
                </div>
                <div class="bg-soft-success border border-success text-success rounded p-3 d-flex align-items-center justify-content-center" style="width: 55px; height: 50px;">
                    <!-- Finans / Cüzdan / Para İkonu -->
                    <span class="fs-4 fw-bold">₺</span>
                </div>
            </div>
        </div>
    </div>

</div>

<hr class="hr-horizontal my-4">

<!-- BURADAN AŞAĞISINA İSTERSENİZ DAHA ÖNCE YAPTIĞINIZ HIZLI TABLOLARI VEYA GRAFİKLERİ EKLEYEBİLİRSİNİZ -->