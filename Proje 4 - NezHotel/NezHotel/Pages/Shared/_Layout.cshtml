<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] — Nez Hotel</title>
    <link rel="stylesheet" href="~/css/tabler-icons.min.css" />
    <style>
            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            :root {
                --navy: #0F1E3A;
                --navy2: #162848;
                --navy3: #1E3560;
                --gold: #C9963A;
                --gold2: #E8B44A;
                --gold3: #F5CC70;
                --sidebar-w: 230px;
                --bg: #F0F2F7;
                --white: #fff;
                --border: #e8eaf0;
                --text: #0F1E3A;
                --muted: #8a8fa8;
                --sub: #5a6278;
            }

            html, body {
                height: 100%;
                font-family: 'Segoe UI', Arial, sans-serif;
                background: var(--bg);
                color: var(--text);
            }

            button {
                cursor: pointer;
                font-family: inherit;
            }

            .layout {
                display: flex;
                height: 100vh;
                overflow: hidden;
            }

            /* Sidebar */
            .sidebar {
                width: var(--sidebar-w);
                background: var(--navy);
                display: flex;
                flex-direction: column;
                flex-shrink: 0;
                height: 100vh;
                position: fixed;
                left: 0;
                top: 0;
                z-index: 100;
            }

            .logo {
                padding: 22px 18px 16px;
                border-bottom: 1px solid rgba(255,255,255,.1);
            }

            .logo-icon {
                width: 36px;
                height: 36px;
                background: var(--gold);
                border-radius: 10px;
                display: flex;
                align-items: center;
                justify-content: center;
                margin-bottom: 12px;
            }

                .logo-icon i {
                    font-size: 20px;
                    color: var(--navy);
                }

            .logo-title {
                font-size: 15px;
                font-weight: 600;
                color: #fff;
            }

            .logo-sub {
                font-size: 11px;
                color: rgba(255,255,255,.4);
                margin-top: 2px;
            }

            nav {
                padding: 14px 10px;
                flex: 1;
                overflow-y: auto;
            }

            .nav-label {
                font-size: 10px;
                color: rgba(255,255,255,.3);
                letter-spacing: 1px;
                text-transform: uppercase;
                padding: 10px 8px 4px;
            }

            .nav-item {
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 10px 12px;
                border-radius: 9px;
                color: rgba(255,255,255,.6);
                font-size: 13.5px;
                transition: all .15s;
                margin-bottom: 3px;
                border: none;
                background: none;
                width: 100%;
                text-align: left;
                text-decoration: none;
            }

                .nav-item:hover {
                    background: rgba(255,255,255,.08);
                    color: #fff;
                }

                .nav-item.active {
                    background: var(--gold);
                    color: var(--navy);
                    font-weight: 600;
                }

                    .nav-item.active i {
                        color: var(--navy);
                    }

                .nav-item i {
                    font-size: 18px;
                    width: 22px;
                    flex-shrink: 0;
                }

            .nav-badge {
                margin-left: auto;
                background: rgba(255,255,255,.2);
                color: #fff;
                font-size: 10px;
                padding: 1px 8px;
                border-radius: 20px;
                font-weight: 500;
            }

            .nav-item.active .nav-badge {
                background: rgba(0,0,0,.15);
                color: var(--navy);
            }

            .sidebar-footer {
                padding: 14px 10px;
                border-top: 1px solid rgba(255,255,255,.08);
            }

            .admin-card {
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 8px 10px;
            }

            .admin-av {
                width: 36px;
                height: 36px;
                border-radius: 50%;
                background: var(--gold3);
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 13px;
                font-weight: 700;
                color: var(--navy);
                flex-shrink: 0;
            }

            .admin-name {
                font-size: 13px;
                color: #fff;
                font-weight: 600;
            }

            .admin-role {
                font-size: 11px;
                color: rgba(255,255,255,.4);
            }

            /* Main */
            .main {
                flex: 1;
                margin-left: var(--sidebar-w);
                display: flex;
                flex-direction: column;
                height: 100vh;
                overflow: hidden;
            }

            /* Topbar */
            .topbar {
                background: var(--white);
                border-bottom: 1px solid var(--border);
                padding: 0 24px;
                height: 58px;
                display: flex;
                align-items: center;
                justify-content: space-between;
                flex-shrink: 0;
            }

            .page-title {
                font-size: 15px;
                font-weight: 600;
                color: var(--navy);
            }

            .page-breadcrumb {
                font-size: 12px;
                color: var(--muted);
                margin-top: 1px;
            }

            .topbar-right {
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .tb-btn {
                width: 36px;
                height: 36px;
                border-radius: 9px;
                border: 1px solid var(--border);
                background: var(--white);
                display: flex;
                align-items: center;
                justify-content: center;
                cursor: pointer;
                color: var(--sub);
                position: relative;
                transition: background .12s;
            }

                .tb-btn:hover {
                    background: #f5f5f8;
                }

                .tb-btn i {
                    font-size: 18px;
                }

            .notif-dot {
                position: absolute;
                top: 7px;
                right: 7px;
                width: 7px;
                height: 7px;
                background: #E24B4A;
                border-radius: 50%;
                border: 2px solid var(--white);
            }

            .date-badge {
                font-size: 12px;
                color: var(--muted);
                background: #f5f5f8;
                padding: 6px 12px;
                border-radius: 7px;
                border: 1px solid var(--border);
                display: flex;
                align-items: center;
                gap: 6px;
            }

                .date-badge i {
                    font-size: 14px;
                }

            /* Content */
            .content {
                flex: 1;
                overflow-y: auto;
                padding: 22px 24px;
            }
    </style>
    @RenderSection("Styles", required: false)
</head>
<body>

    <div class="layout">

        <div class="sidebar">
            <div class="logo">
                <div class="logo-icon"><i class="ti ti-building"></i></div>
                <div class="logo-title">Nez Hotel</div>
                <div class="logo-sub">Yönetim Paneli</div>
            </div>
            <nav>
                <div class="nav-label">Ana Menü</div>

                @{
                    // Razor Pages için şu an aktif olan sayfanın yolunu öğreniyoruz
                    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
                }

                <a class="nav-item @(currentPage == "/Index" || currentPage == "" ? "active" : "")"
                   asp-page="/Index">
                    <i class="ti ti-layout-dashboard"></i> Panel
                </a>

                <a class="nav-item @(currentPage.StartsWith("/Odalar") ? "active" : "")"
                   asp-page="/Odalar/Index">
                    <i class="ti ti-door"></i> Odalar
                </a>

                <a class="nav-item @(currentPage.StartsWith("/Rezervasyonlar") ? "active" : "")"
                   asp-page="/Rezervasyonlar/Index">
                    <i class="ti ti-calendar"></i> Rezervasyonlar
                </a>

                <a class="nav-item @(currentPage.StartsWith("/Musteriler") ? "active" : "")"
                   asp-page="/Musteriler/Index">
                    <i class="ti ti-users"></i> Müşteriler
                </a>
            </nav>

            <div class="sidebar-footer">
                <div class="admin-card">
                    <div class="admin-av">AY</div>
                    <div style="flex: 1;">
                        <div class="admin-name">Adem Eraslan</div>
                        <div class="admin-role">Sistem Yöneticisi</div>
                    </div>
                    <a href="/Account/Logout" title="Çıkış Yap" style="color: rgba(255,255,255,0.6); transition: color 0.2s;" onmouseover="this.style.color='#E24B4A'" onmouseout="this.style.color='rgba(255,255,255,0.6)'">
                        <i class="ti ti-logout" style="font-size: 20px;"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="main">
            <div class="topbar">
                <div>
                    <div class="page-title">@ViewData["Title"]</div>
                    <div class="page-breadcrumb">Panel › @ViewData["Title"]</div>
                </div>
                <div class="topbar-right">
                    <div class="date-badge">
                        <i class="ti ti-calendar"></i>
                        @DateTime.Now.ToString("dd MMMM yyyy", new System.Globalization.CultureInfo("tr-TR"))
                    </div>
                    <button class="tb-btn"><i class="ti ti-search"></i></button>
                    <button class="tb-btn">
                        <i class="ti ti-bell"></i>
                        <div class="notif-dot"></div>
                    </button>
                </div>
            </div>

            <div class="content">
                @RenderBody()
            </div>
        </div>

    </div>

    @RenderSection("Scripts", required: false)
</body>
</html>