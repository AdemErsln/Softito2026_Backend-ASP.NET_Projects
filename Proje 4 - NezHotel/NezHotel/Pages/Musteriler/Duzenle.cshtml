@page
@model NezHotel.Pages.Musteriler.DuzenleModel
@{ ViewData["Title"] = "Müşteri Kartını Düzenle"; }

<div class="form-card">
    <div class="form-header">
        <div class="form-title"><i class="ti ti-edit" style="font-size: 20px; color: var(--gold);"></i> Müşteri Bilgilerini Güncelle</div>
    </div>

    @if (!string.IsNullOrEmpty(Model.Mesaj))
    {
        <div class="alert-box"><i class="ti ti-alert-triangle"></i> @Model.Mesaj</div>
    }

    <form method="post">
        <input type="hidden" asp-for="MusteriID" />
        <div class="form-group">
            <label class="form-label">Adı Soyadı</label>
            <input type="text" asp-for="AdSoyad" class="form-control" required />
        </div>
        <div class="form-group">
            <label class="form-label">Telefon Numarası</label>
            <input type="tel" asp-for="Telefon" class="form-control" />
        </div>
        <div class="form-group">
            <label class="form-label">E-Posta Adresi</label>
            <input type="email" asp-for="Email" class="form-control" />
        </div>
        <div class="form-actions">
            <a href="/Musteriler/Index" class="btn btn-outline">Vazgeç</a>
            <button type="submit" class="btn btn-gold"><i class="ti ti-checkbox"></i> Değişiklikleri Kaydet</button>
        </div>
    </form>
</div>