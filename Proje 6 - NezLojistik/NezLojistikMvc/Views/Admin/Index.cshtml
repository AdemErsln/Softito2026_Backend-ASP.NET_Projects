@model NezLojistikMvc.Controllers.AdminViewModel
@{
    ViewData["Title"] = "Yönetim Paneli - Nez Lojistik";
}

<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    body {
        font-family: 'Outfit', sans-serif;
        background: linear-gradient(135deg, #090d16 0%, #0f172a 100%) !important;
        color: #f1f5f9 !important;
        min-height: 100vh;
        overflow-x: hidden;
    }

    .container {
        max-width: 100% !important;
        padding: 0 !important;
    }

    .navbar, footer {
        display: none !important;
    }

    /* Dashboard Layout */
    .dashboard-wrapper {
        display: flex;
        min-height: 100vh;
    }

    /* Sidebar Styling */
    .sidebar {
        width: 280px;
        background: rgba(9, 13, 22, 0.7);
        backdrop-filter: blur(20px);
        border-right: 1px solid rgba(255, 255, 255, 0.08);
        padding: 2rem 1.5rem;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .sidebar-brand {
        font-size: 1.5rem;
        font-weight: 800;
        color: #38bdf8;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        text-decoration: none;
        margin-bottom: 3rem;
    }

    .sidebar-brand i {
        color: #6366f1;
        filter: drop-shadow(0 0 8px rgba(99, 102, 241, 0.6));
    }

    .menu-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .menu-item {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 0.85rem 1.2rem;
        color: #94a3b8;
        text-decoration: none;
        border-radius: 12px;
        font-weight: 500;
        transition: all 0.3s;
    }

    .menu-item:hover, .menu-item.active {
        color: #ffffff;
        background: rgba(99, 102, 241, 0.15);
        box-shadow: inset 0 0 10px rgba(99, 102, 241, 0.1);
    }

    .menu-item.active {
        border: 1px solid rgba(99, 102, 241, 0.3);
    }

    .menu-item i {
        font-size: 1.15rem;
    }

    .user-profile {
        display: flex;
        align-items: center;
        gap: 1rem;
        padding: 1rem;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 14px;
        margin-top: auto;
    }

    .user-avatar {
        width: 42px;
        height: 42px;
        border-radius: 50%;
        background: linear-gradient(135deg, #38bdf8 0%, #6366f1 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: 700;
        font-size: 1.1rem;
    }

    .user-info {
        text-align: left;
    }

    .user-name {
        font-size: 0.95rem;
        font-weight: 600;
        color: white;
    }

    .user-role {
        font-size: 0.8rem;
        color: #64748b;
    }

    /* Content Area */
    .content-body {
        flex: 1;
        padding: 3rem 4rem;
        overflow-y: auto;
        max-height: 100vh;
    }

    /* Top Bar */
    .top-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 3rem;
    }

    .page-title {
        font-size: 1.8rem;
        font-weight: 800;
        color: #ffffff;
    }

    .page-subtitle {
        font-size: 0.95rem;
        color: #64748b;
        margin-top: 0.25rem;
    }

    .top-actions {
        display: flex;
        gap: 1rem;
    }

    .btn-action {
        padding: 0.65rem 1.4rem;
        border-radius: 10px;
        font-weight: 600;
        font-size: 0.9rem;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        text-decoration: none;
        transition: all 0.3s;
    }

    .btn-pdf {
        background: rgba(239, 68, 68, 0.1);
        border: 1px solid rgba(239, 68, 68, 0.25);
        color: #f87171;
    }

    .btn-pdf:hover {
        background: rgba(239, 68, 68, 0.2);
        border-color: rgba(239, 68, 68, 0.4);
        color: #f87171;
        transform: translateY(-2px);
    }

    .btn-excel {
        background: rgba(16, 185, 129, 0.1);
        border: 1px solid rgba(16, 185, 129, 0.25);
        color: #34d399;
    }

    .btn-excel:hover {
        background: rgba(16, 185, 129, 0.2);
        border-color: rgba(16, 185, 129, 0.4);
        color: #34d399;
        transform: translateY(-2px);
    }

    /* Stats Grid */
    .dashboard-stats {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 2rem;
        margin-bottom: 3rem;
    }

    .stat-box {
        background: rgba(17, 24, 39, 0.4);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 18px;
        padding: 1.75rem 1.5rem;
        display: flex;
        align-items: center;
        gap: 1.25rem;
    }

    .stat-box-icon {
        width: 52px;
        height: 52px;
        border-radius: 14px;
        background: rgba(99, 102, 241, 0.15);
        color: #6366f1;
        font-size: 1.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .stat-box-value {
        font-size: 1.8rem;
        font-weight: 800;
        color: white;
        line-height: 1;
        margin-bottom: 0.25rem;
    }

    .stat-box-label {
        font-size: 0.85rem;
        color: #64748b;
        font-weight: 500;
    }

    /* Content Cards */
    .dashboard-card {
        background: rgba(17, 24, 39, 0.4);
        border: 1px solid rgba(255, 255, 255, 0.06);
        border-radius: 20px;
        padding: 2.25rem;
        margin-bottom: 2.5rem;
        box-shadow: 0 15px 30px rgba(0, 0, 0, 0.2);
    }

    .card-header-custom {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.75rem;
    }

    .card-title-custom {
        font-size: 1.3rem;
        font-weight: 700;
        color: white;
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }

    .card-title-custom i {
        color: #38bdf8;
    }

    /* Premium Tables */
    .table-responsive {
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid rgba(255, 255, 255, 0.05);
    }

    .table-custom {
        width: 100%;
        margin-bottom: 0;
        color: #e2e8f0;
        background: rgba(9, 13, 22, 0.4);
        border-collapse: collapse;
    }

    .table-custom th {
        background: rgba(15, 23, 42, 0.8);
        color: #94a3b8;
        font-weight: 600;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        padding: 1.1rem 1.5rem;
        border-bottom: 2px solid rgba(255, 255, 255, 0.08);
    }

    .table-custom td {
        padding: 1.1rem 1.5rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        font-size: 0.95rem;
        color: #e2e8f0;
    }

    .table-custom tr:hover td {
        background: rgba(255, 255, 255, 0.02);
    }

    .badge-custom {
        padding: 0.35rem 0.75rem;
        border-radius: 20px;
        font-size: 0.8rem;
        font-weight: 600;
        display: inline-block;
    }

    .badge-active {
        background: rgba(16, 185, 129, 0.15);
        color: #34d399;
        border: 1px solid rgba(16, 185, 129, 0.25);
    }
</style>

<div class="dashboard-wrapper">
    <!-- Sidebar -->
    <div class="sidebar">
        <div>
            <a href="/" class="sidebar-brand">
                <i class="fa-solid fa-truck-fast"></i>
                <span>Nez Lojistik</span>
            </a>
            
            <ul class="menu-list">
                <li>
                    <a href="#" class="menu-item active">
                        <i class="fa-solid fa-chart-line"></i>
                        <span>Genel Bakış</span>
                    </a>
                </li>
                <li>
                    <a href="#" class="menu-item">
                        <i class="fa-solid fa-warehouse"></i>
                        <span>Depo Yönetimi</span>
                    </a>
                </li>
                <li>
                    <a href="#" class="menu-item">
                        <i class="fa-solid fa-truck-moving"></i>
                        <span>Araç Filosu</span>
                    </a>
                </li>
                <li>
                    <a href="#" class="menu-item">
                        <i class="fa-solid fa-id-card"></i>
                        <span>Sürücü Kayıtları</span>
                    </a>
                </li>
                <li>
                    <a href="#" class="menu-item">
                        <i class="fa-solid fa-file-invoice-dollar"></i>
                        <span>Raporlar</span>
                    </a>
                </li>
            </ul>
        </div>

        <div class="user-profile">
            <div class="user-avatar">A</div>
            <div class="user-info">
                <div class="user-name">Adem Erslan</div>
                <div class="user-role">Sistem Yöneticisi</div>
            </div>
        </div>
    </div>

    <!-- Main Content -->
    <div class="content-body">
        <!-- Top Bar -->
        <div class="top-bar">
            <div>
                <h1 class="page-title">Sistem Genel Raporları</h1>
                <div class="page-subtitle">Depo, araç ve sürücü verilerinin anlık senkronizasyonu.</div>
            </div>
            
            <div class="top-actions">
                <a href="#" class="btn-action btn-pdf">
                    <i class="fa-regular fa-file-pdf"></i> PDF Raporu Al
                </a>
                <a href="#" class="btn-action btn-excel">
                    <i class="fa-regular fa-file-excel"></i> Excel Çıktısı Al
                </a>
            </div>
        </div>

        <!-- Stats Boxes -->
        <div class="dashboard-stats">
            <div class="stat-box">
                <div class="stat-box-icon" style="background: rgba(99,102,241,0.12); color: #6366f1;">
                    <i class="fa-solid fa-warehouse"></i>
                </div>
                <div>
                    <div class="stat-box-value">@Model.Depots.Count</div>
                    <div class="stat-box-label">Toplam Depo</div>
                </div>
            </div>
            <div class="stat-box">
                <div class="stat-box-icon" style="background: rgba(14,165,233,0.12); color: #0ea5e9;">
                    <i class="fa-solid fa-truck-moving"></i>
                </div>
                <div>
                    <div class="stat-box-value">@Model.Vehicles.Count</div>
                    <div class="stat-box-label">Toplam Araç</div>
                </div>
            </div>
            <div class="stat-box">
                <div class="stat-box-icon" style="background: rgba(16,185,129,0.12); color: #10b981;">
                    <i class="fa-solid fa-id-card"></i>
                </div>
                <div>
                    <div class="stat-box-value">@Model.Drivers.Count</div>
                    <div class="stat-box-label">Kayıtlı Sürücü</div>
                </div>
            </div>
        </div>

        <!-- Depots Grid/Table -->
        <div class="dashboard-card">
            <div class="card-header-custom">
                <h3 class="card-title-custom">
                    <i class="fa-solid fa-warehouse"></i> Akıllı Depo Listesi
                </h3>
            </div>
            
            <div class="table-responsive">
                <table class="table table-custom">
                    <thead>
                        <tr>
                            <th style="width: 80px;">ID</th>
                            <th>DEPO ADI</th>
                            <th>ŞEHİR</th>
                            <th>ADRES</th>
                            <th style="width: 150px; text-align: center;">DURUM</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var depot in Model.Depots)
                        {
                            <tr>
                                <td>#@depot.Id</td>
                                <td style="font-weight: 600; color: #fff;">@depot.DepotName</td>
                                <td>@depot.City</td>
                                <td class="text-muted">@depot.Address</td>
                                <td style="text-align: center;">
                                    <span class="badge-custom badge-active">Aktif</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Row for Vehicles & Drivers -->
        <div class="row">
            <!-- Vehicles -->
            <div class="col-lg-6 pr-lg-3">
                <div class="dashboard-card" style="height: 100%;">
                    <div class="card-header-custom">
                        <h3 class="card-title-custom">
                            <i class="fa-solid fa-truck-moving"></i> Aktif Araç Filosu
                        </h3>
                    </div>
                    
                    <div class="table-responsive">
                        <table class="table table-custom">
                            <thead>
                                <tr>
                                    <th>PLAKA</th>
                                    <th>MARKA / MODEL</th>
                                    <th>KAPASİTE</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var vehicle in Model.Vehicles)
                                {
                                    <tr>
                                        <td style="font-weight: 700; color: #38bdf8;">@vehicle.Plate</td>
                                        <td style="font-weight: 600;">@vehicle.Brand</td>
                                        <td>@vehicle.Capacity kg</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Drivers -->
            <div class="col-lg-6 pl-lg-3">
                <div class="dashboard-card" style="height: 100%;">
                    <div class="card-header-custom">
                        <h3 class="card-title-custom">
                            <i class="fa-solid fa-id-card"></i> Sürücü Personel Kayıtları
                        </h3>
                    </div>
                    
                    <div class="table-responsive">
                        <table class="table table-custom">
                            <thead>
                                <tr>
                                    <th>AD SOYAD</th>
                                    <th>TELEFON NO</th>
                                    <th>EHLİYET</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var driver in Model.Drivers)
                                {
                                    <tr>
                                        <td style="font-weight: 600; color: #fff;">@driver.FullName</td>
                                        <td>@driver.PhoneNumber</td>
                                        <td><span class="text-muted font-weight-bold">@driver.LicenseNumber</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>
