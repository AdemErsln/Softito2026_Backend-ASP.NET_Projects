@{
    ViewData["Title"] = "Giriş Yap - Nez Lojistik";
}

<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&display=swap">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
    body {
        font-family: 'Outfit', sans-serif;
        background: linear-gradient(135deg, #090d16 0%, #1e1b4b 100%) !important;
        color: #f1f5f9 !important;
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        position: relative;
        overflow: hidden;
    }

    .navbar, footer {
        display: none !important;
    }

    /* Glow spheres behind the form */
    .glow-sphere {
        position: absolute;
        border-radius: 50%;
        filter: blur(120px);
        z-index: -1;
        pointer-events: none;
    }

    .sphere-1 {
        width: 350px;
        height: 350px;
        background: rgba(99, 102, 241, 0.18);
        top: 10%;
        left: 15%;
    }

    .sphere-2 {
        width: 400px;
        height: 400px;
        background: rgba(14, 165, 233, 0.15);
        bottom: 10%;
        right: 15%;
    }

    /* Login Container */
    .login-container {
        background: rgba(17, 24, 39, 0.45);
        backdrop-filter: blur(25px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 28px;
        padding: 3.5rem 3rem;
        width: 100%;
        max-width: 480px;
        box-shadow: 0 30px 60px rgba(0, 0, 0, 0.4);
        text-align: center;
        position: relative;
    }

    .brand-logo {
        font-size: 2.2rem;
        font-weight: 800;
        color: #38bdf8;
        display: inline-flex;
        align-items: center;
        gap: 0.75rem;
        text-decoration: none;
        margin-bottom: 2rem;
        letter-spacing: 0.5px;
    }

    .brand-logo i {
        color: #6366f1;
        filter: drop-shadow(0 0 10px rgba(99, 102, 241, 0.8));
    }

    .login-title {
        font-size: 1.6rem;
        font-weight: 700;
        color: #ffffff;
        margin-bottom: 0.5rem;
    }

    .login-subtitle {
        font-size: 0.95rem;
        color: #94a3b8;
        margin-bottom: 2.5rem;
        font-weight: 400;
    }

    /* Form Fields */
    .form-group-custom {
        text-align: left;
        margin-bottom: 1.5rem;
        position: relative;
    }

    .form-label-custom {
        display: block;
        font-size: 0.9rem;
        font-weight: 600;
        color: #94a3b8;
        margin-bottom: 0.5rem;
        letter-spacing: 0.5px;
    }

    .input-wrapper {
        position: relative;
    }

    .input-wrapper i {
        position: absolute;
        left: 1.2rem;
        top: 50%;
        transform: translateY(-50%);
        color: #64748b;
        font-size: 1.1rem;
        transition: color 0.3s;
    }

    .form-input-custom {
        width: 100%;
        background: rgba(9, 13, 22, 0.6);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        padding: 0.95rem 1.2rem 0.95rem 3rem;
        color: #ffffff;
        font-size: 1rem;
        transition: all 0.3s;
    }

    .form-input-custom:focus {
        outline: none;
        border-color: #6366f1;
        box-shadow: 0 0 10px rgba(99, 102, 241, 0.25);
    }

    .form-input-custom:focus + i {
        color: #6366f1;
    }

    /* Action bar */
    .action-bar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 2rem;
        font-size: 0.9rem;
    }

    .checkbox-custom {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        color: #94a3b8;
        cursor: pointer;
        user-select: none;
    }

    .checkbox-custom input {
        accent-color: #6366f1;
        width: 16px;
        height: 16px;
    }

    .forgot-link {
        color: #38bdf8;
        text-decoration: none;
        font-weight: 500;
        transition: color 0.3s;
    }

    .forgot-link:hover {
        color: #6366f1;
    }

    /* Submit Button */
    .btn-login-submit {
        width: 100%;
        background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
        border: none;
        border-radius: 12px;
        color: white;
        padding: 1rem;
        font-weight: 700;
        font-size: 1.1rem;
        cursor: pointer;
        box-shadow: 0 4px 15px rgba(99, 102, 241, 0.35);
        transition: all 0.3s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.6rem;
    }

    .btn-login-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(99, 102, 241, 0.55);
    }

    /* Footer Links */
    .back-home {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        margin-top: 2.5rem;
        color: #64748b;
        text-decoration: none;
        font-size: 0.95rem;
        font-weight: 500;
        transition: color 0.3s;
    }

    .back-home:hover {
        color: #e2e8f0;
    }
</style>

<div class="glow-sphere sphere-1"></div>
<div class="glow-sphere sphere-2"></div>

<div class="login-container">
    <a href="/" class="brand-logo">
        <i class="fa-solid fa-truck-fast"></i>
        <span>Nez Lojistik</span>
    </a>
    
    <h2 class="login-title">Tekrar Hoş Geldiniz</h2>
    <p class="login-subtitle">Devam etmek için sistem giriş bilgilerinizi giriniz.</p>

    <form onsubmit="event.preventDefault(); window.location.href='/Admin';">
        <div class="form-group-custom">
            <label class="form-label-custom">E-POSTA ADRESİ</label>
            <div class="input-wrapper">
                <input type="email" class="form-input-custom" placeholder="admin@nezlojistik.com" value="admin@nezlojistik.com" required />
                <i class="fa-regular fa-envelope"></i>
            </div>
        </div>

        <div class="form-group-custom">
            <label class="form-label-custom">ŞİFRE</label>
            <div class="input-wrapper">
                <input type="password" class="form-input-custom" placeholder="••••••••" value="admin123" required />
                <i class="fa-solid fa-lock"></i>
            </div>
        </div>

        <div class="action-bar">
            <label class="checkbox-custom">
                <input type="checkbox" checked />
                Beni Hatırla
            </label>
            <a href="#" class="forgot-link">Şifremi Unuttum</a>
        </div>

        <button type="submit" class="btn-login-submit">
            <span>Sisteme Giriş Yap</span>
            <i class="fa-solid fa-arrow-right"></i>
        </button>
    </form>

    <a href="/" class="back-home">
        <i class="fa-solid fa-arrow-left-long"></i> Ana Sayfaya Dön
    </a>
</div>
