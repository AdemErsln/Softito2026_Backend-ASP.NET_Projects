@model IEnumerable<StudentViewModel>
@{
    ViewData["Title"] = "Öğrenci Yönetimi";
}

<div class="space-y-6">
    <div class="flex justify-between items-center bg-slate-900 p-6 rounded-2xl border border-slate-800">
        <div>
            <h2 class="text-xl font-bold text-white">Öğrenci Listesi</h2>
            <p class="text-xs text-slate-400 mt-1">Öğrenci profillerini yönetin, düzenleyin ve atandıkları sınıfları inceleyin.</p>
        </div>
        <a href="/Student/Create" class="px-5 py-2.5 text-sm font-semibold rounded-xl bg-indigo-600 hover:bg-indigo-500 text-white transition duration-200 shadow-lg shadow-indigo-500/20">
            ➕ Yeni Öğrenci Ekle
        </a>
    </div>

    <div class="bg-slate-900 border border-slate-800 rounded-2xl overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left text-sm border-collapse">
                <thead>
                    <tr class="text-xs font-semibold text-slate-400 border-b border-slate-800 bg-slate-950/40 uppercase">
                        <th class="px-6 py-4">Öğrenci No</th>
                        <th class="px-6 py-4">Ad Soyad</th>
                        <th class="px-6 py-4">E-posta</th>
                        <th class="px-6 py-4">Sınıf</th>
                        <th class="px-6 py-4 text-center">İşlemler</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-800">
                    @if (Model.Any())
                    {
                        foreach (var student in Model)
                        {
                            <tr class="hover:bg-slate-800/20 transition">
                                <td class="px-6 py-4 font-bold text-indigo-400">@student.StudentNumber</td>
                                <td class="px-6 py-4 text-slate-200">@student.FirstName @student.LastName</td>
                                <td class="px-6 py-4 text-slate-400">@(student.Email ?? "-")</td>
                                <td class="px-6 py-4">
                                    @if (student.ClassroomId != null)
                                    {
                                        <a href="/Classroom/Details/@student.ClassroomId" class="inline-flex px-2.5 py-1 rounded-md text-xs font-semibold bg-indigo-500/10 text-indigo-400 border border-indigo-500/20 hover:bg-indigo-500/20 transition">
                                            @student.ClassroomName
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="inline-flex px-2.5 py-1 rounded-md text-xs font-semibold bg-amber-500/10 text-amber-400 border border-amber-500/20">
                                            Sınıfsız
                                        </span>
                                    }
                                </td>
                                <td class="px-6 py-4">
                                    <div class="flex items-center justify-center gap-2">
                                        <a href="/Student/Edit/@student.ID" class="px-3 py-1.5 text-xs font-bold bg-amber-500/10 hover:bg-amber-500/20 text-amber-400 rounded-lg border border-amber-500/20 transition">Düzenle</a>
                                        <a href="/Student/Delete/@student.ID" onclick="return confirm('Bu öğrenciyi silmek istediğinize emin misiniz?')" class="px-3 py-1.5 text-xs font-bold bg-red-500/10 hover:bg-red-500/20 text-red-400 rounded-lg border border-red-500/20 transition">Sil</a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="px-6 py-12 text-center text-slate-500">Henüz hiçbir öğrenci eklenmemiş.</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
