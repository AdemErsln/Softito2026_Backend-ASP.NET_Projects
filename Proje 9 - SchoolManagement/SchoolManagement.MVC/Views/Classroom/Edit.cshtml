@model ClassroomViewModel
@{
    ViewData["Title"] = $"{Model.Name} Düzenle";
}

<div class="max-w-xl mx-auto space-y-6">
    <div class="flex items-center gap-4">
        <a href="/Classroom" class="text-sm font-semibold text-indigo-400 hover:underline">← Sınıflara Geri Dön</a>
    </div>

    <div class="bg-slate-900 border border-slate-800 p-8 rounded-2xl space-y-6">
        <div>
            <h2 class="text-2xl font-bold text-white">Sınıfı Düzenle</h2>
            <p class="text-xs text-slate-400 mt-1">Sınıf bilgilerini veya kapasitesini güncelleyin.</p>
        </div>

        <form asp-action="Edit" method="post" class="space-y-5">
            <input type="hidden" asp-for="ID" />
            <div asp-validation-summary="ModelOnly" class="text-sm text-red-400"></div>

            <div class="space-y-2">
                <label asp-for="Name" class="text-xs font-semibold text-slate-400">Sınıf Adı</label>
                <input asp-for="Name" type="text" required class="w-full bg-slate-950 border border-slate-800 rounded-xl px-4 py-2.5 text-sm text-slate-200 outline-none focus:border-indigo-500 transition" />
                <span asp-validation-for="Name" class="text-xs text-red-400"></span>
            </div>

            <div class="space-y-2">
                <label asp-for="Capacity" class="text-xs font-semibold text-slate-400">Kapasite</label>
                <input asp-for="Capacity" type="number" min="1" required class="w-full bg-slate-950 border border-slate-800 rounded-xl px-4 py-2.5 text-sm text-slate-200 outline-none focus:border-indigo-500 transition" />
                <span asp-validation-for="Capacity" class="text-xs text-red-400"></span>
            </div>

            <div class="space-y-2">
                <label asp-for="Location" class="text-xs font-semibold text-slate-400">Lokasyon / Kat</label>
                <input asp-for="Location" type="text" class="w-full bg-slate-950 border border-slate-800 rounded-xl px-4 py-2.5 text-sm text-slate-200 outline-none focus:border-indigo-500 transition" />
                <span asp-validation-for="Location" class="text-xs text-red-400"></span>
            </div>

            <div class="pt-2">
                <button type="submit" class="w-full py-3 bg-indigo-600 hover:bg-indigo-500 transition duration-200 rounded-xl font-bold text-sm text-white shadow-lg shadow-indigo-500/20">
                    Değişiklikleri Kaydet
                </button>
            </div>
        </form>
    </div>
</div>
