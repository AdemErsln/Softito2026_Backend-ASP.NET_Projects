@{
    Layout = "~/Views/Shared/adminLayout.cshtml";
}
@model IEnumerable<Project_First.Models.AnimalTypes>


<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Tür Yönetimi</h1>
    <a href="/AnimalTypes/Create" class="d-none d-sm-inline-block btn btn-sm btn-primary shadow-sm">
        <i class="fas fa-plus fa-sm text-white-50 mr-1"></i> Yeni Tür Ekle
    </a>
</div>

<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Kayıtlı Hayvan Türleri</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-striped table-hover" width="100%" cellspacing="0">
                <thead class="thead-light">
                    <tr>
                        <th style="width: 15%;">ID</th>
                        <th>Tür Adı</th>
                        <th style="width: 25%;" class="text-center">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td><span class="font-weight-bold text-dark">@item.animal_type</span></td>
                                <td class="text-center">
                                    <div class="d-flex justify-content-center align-items-center">
                                        <a href="/AnimalTypes/Edit/@item.Id" class="btn btn-sm btn-warning btn-icon-split mr-2">
                                            <span class="icon text-white-50"><i class="fas fa-edit"></i></span>
                                            <span class="text">Düzenle</span>
                                        </a>

                                        <form action="/AnimalTypes/Delete/@item.Id" method="post" onsubmit="return confirm('@item.animal_type türünü silmek istediğinize emin misiniz?');" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-danger btn-icon-split">
                                                <span class="icon text-white-50"><i class="fas fa-trash"></i></span>
                                                <span class="text">Sil</span>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" class="text-center text-muted py-4">
                                <i class="fas fa-tags fa-2x mb-2 d-block"></i> Tanımlı hayvan türü bulunamadı.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>