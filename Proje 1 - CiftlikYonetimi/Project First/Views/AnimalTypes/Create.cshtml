@model Project_First.Models.AnimalTypes

@{
    Layout = "~/Views/Shared/adminLayout.cshtml";
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">Tür Yönetimi</h1>
    <a href="/AnimalTypes/Index" class="d-none d-sm-inline-block btn btn-sm btn-secondary shadow-sm">
        <i class="fas fa-arrow-left fa-sm text-white-50 mr-1"></i> Listeye Dön
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">Yeni Tür Tanımlama Formu</h6>
            </div>
            <div class="card-body">
                <form action="/AnimalTypes/Create" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="form-group mb-4">
                        <label asp-for="animal_type" class="font-weight-bold text-dark">Tür Adı</label>
                        <div class="input-group">
                            <div class="input-group-prepend">
                                <span class="input-group-text bg-light"><i class="fas fa-tag text-primary"></i></span>
                            </div>
                            <input asp-for="animal_type" class="form-control" placeholder="Örn: Büyükbaş, Küçükbaş, Kanatlı" required />
                        </div>
                        <span asp-validation-for="animal_type" class="text-danger small"></span>
                    </div>

                    <hr class="my-4">

                    <div class="d-flex justify-content-end">
                        <a href="/AnimalTypes/Index" class="btn btn-light mr-2">İptal</a>
                        <button type="submit" class="btn btn-primary btn-icon-split">
                            <span class="icon text-white-50"><i class="fas fa-save"></i></span>
                            <span class="text">Türü Kaydet</span>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>