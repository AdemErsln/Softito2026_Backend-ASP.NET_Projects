<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>@ViewData["Title"] - K-Yonetim</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="/css/bootstrap-icons.css" rel="stylesheet" />

    <style>
            :root {
                --bg-dark-purple: #1a1625;
                --sidebar-purple: #261e35;
                --accent-purple: #6f42c1;
                --hover-purple: #8c52ff;
                --text-light: #f3effa;
                --card-purple: #2d243f;
            }

            * {
                box-sizing: border-box;
            }

            body {
                background-color: var(--bg-dark-purple);
                color: var(--text-light);
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                margin: 0;
                padding: 0;
                overflow-x: hidden;
            }

            /* Ekranı tam kaplayan esnek ana taşıyıcı */
            .main-wrapper {
                display: flex;
                min-height: 100vh;
                width: 100vw;
            }

            /* Sabit Sidebar genişliği */
            .sidebar {
                background-color: var(--sidebar-purple);
                width: 240px;
                flex-shrink: 0;
                border-right: 1px solid rgba(255, 255, 255, 0.05);
                display: flex;
                flex-direction: column;
                position: relative;
            }

                .sidebar .nav-link {
                    color: rgba(243, 239, 250, 0.7);
                    padding: 12px 20px;
                    margin: 5px 10px;
                    border-radius: 8px;
                    transition: all 0.3s ease;
                    display: block;
                    text-decoration: none;
                }

                    .sidebar .nav-link:hover, .sidebar .nav-link.active {
                        background-color: var(--accent-purple);
                        color: var(--text-light);
                    }

            /* Sağ taraf esnek içerik alanı */
            .content-area {
                flex-grow: 1;
                padding: 2rem;
                background-color: var(--bg-dark-purple);
                overflow-y: auto;
            }

            /* Ortak RenderBody Bileşen Stilleri */
            .card {
                background-color: var(--card-purple);
                border: none;
                border-radius: 12px;
                color: var(--text-light);
                box-shadow: 0 4px 15px rgba(0,0,0,0.2);
            }

            .table {
                color: var(--text-light) !important;
                width: 100%;
            }

                .table th {
                    background-color: rgba(0, 0, 0, 0.2) !important;
                    color: var(--hover-purple) !important;
                    border-bottom: 2px solid rgba(255, 255, 255, 0.1) !important;
                }

                .table td {
                    background-color: transparent !important;
                    border-bottom: 1px solid rgba(255, 255, 255, 0.05) !important;
                    color: var(--text-light) !important;
                    vertical-align: middle;
                }

            .btn-purple {
                background-color: var(--accent-purple);
                color: var(--text-light);
                border: none;
            }

                .btn-purple:hover {
                    background-color: var(--hover-purple);
                    color: var(--text-light);
                }

            .form-control, .form-select {
                background-color: rgba(0, 0, 0, 0.2);
                border: 1px solid rgba(255, 255, 255, 0.1);
                color: var(--text-light);
            }

                .form-control:focus, .form-select:focus {
                    background-color: rgba(0, 0, 0, 0.3);
                    border-color: var(--hover-purple);
                    color: var(--text-light);
                    box-shadow: 0 0 0 0.25rem rgba(140, 82, 255, 0.25);
                }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <div class="main-wrapper">
        <nav class="sidebar">
            <div class="pt-3">
                <div class="px-4 py-3 d-flex align-items-center">
                    <i class="bi bi-journal-bookmark-fill fs-3 me-2" style="color: var(--hover-purple);"></i>
                    <h4 class="m-0 fw-bold">K-Yönetim</h4>
                </div>
                <hr class="mx-3 opacity-25 text-light">

                <div class="nav flex-column">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Authors" ? "active" : "")"
                       asp-controller="Authors" asp-action="Index">
                        <i class="bi bi-people-fill me-2"></i> Yazarlar
                    </a>
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Books" ? "active" : "")"
                       asp-controller="Books" asp-action="Index">
                        <i class="bi bi-book-half me-2"></i> Kitaplar
                    </a>
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Borrowers" ? "active" : "")"
                       asp-controller="Borrowers" asp-action="Index">
                        <i class="bi bi-arrow-left-right me-2"></i> Ödünç Alanlar
                    </a>
                </div>
            </div>

            <div class="mt-auto p-3">
                <a asp-controller="Account" asp-action="Logout" class="btn btn-outline-danger w-100 btn-sm">
                    <i class="bi bi-box-arrow-left me-1"></i> Çıkış Yap
                </a>
            </div>
        </nav>

        <main class="content-area">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>