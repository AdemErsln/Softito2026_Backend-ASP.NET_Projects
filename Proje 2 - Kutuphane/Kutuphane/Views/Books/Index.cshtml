@model IEnumerable<Kutuphane.Models.Book>
@{
    Layout = "~/views/shared/admin.cshtml";
    ViewData["Title"] = "Kitap Yönetimi";
}

<div class="d-flex justify-content-between align-items-center pb-3 mb-4 border-bottom border-secondary" style="border-color: rgba(255,255,255,0.1) !important;">
    <div>
        <h1 class="h2 mb-0">Kitap Yönetimi</h1>
        <p class="text-muted small mb-0">Kütüphanedeki tüm kitapların listesi ve yazar eşleşmeleri</p>
    </div>
    <div>
        <a asp-action="Create" class="btn btn-purple px-4 py-2 fw-semibold">
            <i class="bi bi-plus-lg me-2"></i>Yeni Kitap Ekle
        </a>
    </div>
</div>

<div class="row mb-4 g-3 align-items-center">
    <div class="col-md-6">
        <form method="get" asp-action="Index" class="d-flex gap-2">
            <input type="text" name="searchString" class="form-control" placeholder="Kitap veya yazar adı ile ara..." value="@ViewBag.SearchString" style="background-color: rgba(0,0,0,0.2); border: 1px solid rgba(255,255,255,0.1); color: var(--text-light);" />
            <button type="submit" class="btn btn-purple"><i class="bi bi-search"></i> Ara</button>
            @if (!string.IsNullOrEmpty(ViewBag.SearchString))
            {
                <a asp-action="Index" class="btn btn-outline-secondary"><i class="bi bi-x-lg"></i> Temizle</a>
            }
        </form>
    </div>
    <div class="col-md-6 text-md-end">
        <a asp-action="ExportToExcel" class="btn btn-success px-3 py-2 fw-semibold me-2">
            <i class="bi bi-file-earmark-excel me-2"></i>Excel Çıktısı
        </a>
        <a asp-action="ExportToPdf" class="btn btn-danger px-3 py-2 fw-semibold">
            <i class="bi bi-file-earmark-pdf me-2"></i>PDF Çıktısı
        </a>
    </div>
</div>

<div class="card shadow-lg">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th class="ps-4" style="width: 10%">#ID</th>
                        <th style="width: 40%">Kitap Adı</th>
                        <th style="width: 20%">Yazar</th>
                        <th style="width: 15%">Yayın Yılı</th>
                        <th class="text-end pe-4" style="width: 15%">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-secondary">@item.BookId</td>
                                <td class="fw-semibold text-white">@item.Title</td>
                                <td>
                                    <span class="badge bg-opacity-25 bg-info text-info px-2 py-1">
                                        <i class="bi bi-person-fill me-1"></i>@item.Author?.Name
                                    </span>
                                </td>
                                <td class="text-muted">@item.PublishYear</td>
                                <td class="text-end pe-4">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Edit" asp-route-id="@item.BookId" class="btn btn-sm btn-outline-warning me-2 rounded" title="Güncelle">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <button type="button" class="btn btn-sm btn-outline-danger rounded" title="Sil" onclick="confirmDelete('@item.BookId', '@item.Title')">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted">
                                <i class="bi bi-book fs-1 d-block mb-3 opacity-50"></i>
                                Henüz hiç kitap eklenmemiş.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<form id="deleteForm" asp-action="Delete" method="post" style="display:none;">
    <input type="hidden" id="deleteId" name="id" />
</form>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script>
    function confirmDelete(id, title) {
        Swal.fire({
            title: 'Emin misiniz?',
            text: `"${title}" isimli kitap silinecektir!`,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#dc3545',
            cancelButtonColor: '#6c757d',
            confirmButtonText: 'Evet, Sil!',
            cancelButtonText: 'Vazgeç'
        }).then((result) => {
            if (result.isConfirmed) {
                document.getElementById('deleteId').value = id;
                document.getElementById('deleteForm').submit();
            }
        })
    }
</script>