@model Kutuphane.Models.Borrower
@{
    Layout = "~/views/shared/admin.cshtml";
    ViewData["Title"] = "Ödünç Ver";
}

<div class="d-flex justify-content-between align-items-center pb-3 mb-4 border-bottom border-secondary" style="border-color: rgba(255,255,255,0.1) !important;">
    <div>
        <h1 class="h2 mb-0">Yeni Ödünç Kaydı</h1>
        <p class="text-muted small mb-0">Kitap ödünç alacak üye bilgilerini giriniz.</p>
    </div>
    <div>
        <a asp-action="Index" class="btn btn-outline-light btn-sm px-3 py-2 fw-semibold opacity-75">
            <i class="bi bi-arrow-left me-2"></i>Geri Dön
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-lg">
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="mb-4">
                        <label asp-for="FullName" class="form-label small fw-semibold opacity-75 mb-2">Adı Soyadı</label>
                        <input asp-for="FullName" class="form-control py-2" placeholder="Örn: Ahmet Yılmaz" autocomplete="off" />
                        <span asp-validation-for="FullName" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="BookId" class="form-label small fw-semibold opacity-75 mb-2">Ödünç Alınacak Kitap</label>
                        <select asp-for="BookId" class="form-select py-2" asp-items="ViewBag.BookId">
                            <option value="">-- Kitap Seçiniz --</option>
                        </select>
                        <span asp-validation-for="BookId" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="BorrowDate" class="form-label small fw-semibold opacity-75 mb-2">Ödünç Alma Tarihi</label>
                        <input asp-for="BorrowDate" type="date" class="form-control py-2" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                        <span asp-validation-for="BorrowDate" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="d-flex justify-content-end gap-2 pt-3 border-top border-secondary" style="border-color: rgba(255,255,255,0.05) !important;">
                        <a asp-action="Index" class="btn btn-sm btn-secondary bg-opacity-25 border-0 px-4 py-2" style="background-color: rgba(255,255,255,0.1);">Vazgeç</a>
                        <button type="submit" class="btn btn-purple btn-sm px-4 py-2 fw-semibold">
                            <i class="bi bi-plus-lg me-2"></i>Ödünç Ver
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }