@model Kutuphane.Models.Author
@{
    Layout = "~/views/shared/admin.cshtml";
    ViewData["Title"] = "Yazar Düzenle";
}

<div class="d-flex justify-content-between align-items-center pb-3 mb-4 border-bottom border-secondary" style="border-color: rgba(255,255,255,0.1) !important;">
    <div>
        <h1 class="h2 mb-0" style="color: var(--text-light);">Yazar Düzenle</h1>
        <p class="text-muted small mb-0">Mevcut yazarın bilgilerini bu ekrandan güncelleyebilirsiniz.</p>
    </div>
    <div>
        <a asp-action="Index" class="btn btn-outline-light btn-sm px-3 py-2 fw-semibold opacity-75 hover-opacity-100">
            <i class="bi bi-arrow-left me-2"></i>Listeye Geri Dön
        </a>
    </div>
</div>

<div class="row">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow-lg">
            <div class="card-body p-4">

                <div class="d-flex align-items-center mb-4">
                    <i class="bi bi-pencil-square fs-4 me-2 text-warning"></i>
                    <h5 class="m-0 fw-bold text-warning">Yazar Bilgilerini Güncelle</h5>
                </div>

                <form asp-action="Edit" method="post">
                    @* Güvenlik ve ID eşleşmesi için gizli input *@
                    <input type="hidden" asp-for="AuthorId" />

                    @* Model hata özet alanı *@
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="mb-4">
                        <label asp-for="Name" class="form-label small fw-semibold opacity-75 mb-2">Yazar Adı</label>
                        <input asp-for="Name" class="form-control py-2" placeholder="Örn: Fyodor Dostoyevski" autocomplete="off" />
                        <span asp-validation-for="Name" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Country" class="form-label small fw-semibold opacity-75 mb-2">Ülke</label>
                        <input asp-for="Country" class="form-control py-2" placeholder="Örn: Rusya" autocomplete="off" />
                        <span asp-validation-for="Country" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="d-flex justify-content-end gap-2 pt-3 border-top border-secondary" style="border-color: rgba(255,255,255,0.05) !important;">
                        <a asp-action="Index" class="btn btn-sm btn-secondary bg-opacity-25 border-0 px-4 py-2" style="background-color: rgba(255,255,255,0.1);">Vazgeç</a>
                        <button type="submit" class="btn btn-purple btn-sm px-4 py-2 fw-semibold">
                            <i class="bi bi-check-lg me-2"></i>Değişiklikleri Kaydet
                        </button>
                    </div>
                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    @* Sayfa yenilenmeden boş geçme kontrollerini yapması için validasyon scriptleri *@
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}