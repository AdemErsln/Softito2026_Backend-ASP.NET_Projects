@model Kutuphane.Models.Author

@{
    Layout = "~/views/shared/admin.cshtml";
}


<div class="d-flex justify-content-between align-items-center pb-3 mb-4 border-bottom border-secondary">
    <div>
        <h1 class="h2 mb-0">Yeni Yazar Ekle</h1>
        <p class="text-muted small mb-0">Sisteme yeni bir yazar kaydetmek için aşağıdaki formu doldurun</p>
    </div>
    <div>
        <a asp-action="Index" class="btn btn-outline-secondary px-3 py-2 btn-sm rounded-3">
            <i class="bi bi-arrow-left me-2"></i>Listeye Geri Dön
        </a>
    </div>
</div>

<div class="row justify-content-start">
    <div class="col-12 col-lg-6">
        <div class="card shadow-lg border-0">
            <div class="card-body p-4">

                <form asp-action="Create" method="post" autocomplete="off">

                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3 fw-bold"></div>

                    <div class="mb-4">
                        <label asp-for="Name" class="form-label fw-semibold mb-2">Yazar Adı Soyadı</label>
                        <div class="input-group">
                            <span class="input-group-text bg-black bg-opacity-20 border-secondary text-muted">
                                <i class="bi bi-person-fill"></i>
                            </span>
                            <input asp-for="Name" class="form-control" placeholder="Örn: Albert Camus" required />
                        </div>
                        <span asp-validation-for="Name" class="text-danger small d-block mt-1"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Country" class="form-label fw-semibold mb-2">Geldiği Ülke</label>
                        <div class="input-group">
                            <span class="input-group-text bg-black bg-opacity-20 border-secondary text-muted">
                                <i class="bi bi-globe"></i>
                            </span>
                            <input asp-for="Country" class="form-control" placeholder="Örn: Fransa" />
                        </div>
                        <span asp-validation-for="Country" class="text-danger small d-block mt-1"></span>
                    </div>

                    <hr class="border-secondary my-4 opacity-25">

                    <div class="d-flex justify-content-end gap-2">
                        <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2">İptal</a>
                        <button type="submit" class="btn btn-purple px-5 py-2 fw-semibold">
                            <i class="bi bi-check-lg me-1"></i> Yazarı Kaydet
                        </button>
                    </div>

                </form>

            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
}