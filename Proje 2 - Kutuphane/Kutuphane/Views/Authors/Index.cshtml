@model IEnumerable<Kutuphane.Models.Author> 
@{
    Layout = "~/views/shared/admin.cshtml";
}

<div class="d-flex justify-content-between align-items-center pb-3 mb-4 border-bottom border-secondary">
    <div>
        <h1 class="h2 mb-0">Yazar Yönetimi</h1>
        <p class="text-muted small mb-0">Kütüphanede tanımlı olan tüm yazarların listesi</p>
    </div>
    <div>
        <a asp-action="Create" class="btn btn-purple px-4 py-2 fw-semibold">
            <i class="bi bi-plus-lg me-2"></i>Yeni Yazar Ekle
        </a>
    </div>
</div>

<div class="card shadow-lg">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th class="ps-4" style="width: 10%">#ID</th>
                        <th style="width: 45%">Yazar Adı</th>
                        <th style="width: 25%">Ülke</th>
                        <th class="text-end pe-4" style="width: 20%">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-secondary">@item.AuthorId</td>
                                <td class="fw-semibold text-white">@item.Name</td>
                                <td>
                                    @if (string.IsNullOrEmpty(item.Country))
                                    {
                                        <span class="text-muted fst-italic">Belirtilmemiş</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-opacity-25 bg-info text-info px-2 py-1">@item.Country</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Edit" asp-route-id="@item.AuthorId" class="btn btn-sm btn-outline-warning me-2 rounded" title="Güncelle">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.AuthorId" class="btn btn-sm btn-outline-danger rounded" title="Sil">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                <i class="bi bi-people fs-1 d-block mb-3 opacity-50"></i>
                                Henüz hiç yazar eklenmemiş. Başlamak için yukarıdaki butonu kullanın!
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>