@{
    Layout = "~/views/shared/admin.cshtml";
    ViewData["Title"] = "Panel";
}

<!-- Üst Karşılama Alanı - text-white ile siyah görünme sorunu çözüldü -->
<div class="pb-2 mb-4 border-bottom" style="border-color: rgba(255,255,255,0.1) !important;">
    <h1 class="h3 mb-1 text-white fw-bold">Kütüphane Özet Paneli</h1>
    <p class=" small mb-0">Sistemdeki genel durumun kısa özeti</p>
</div>

<!-- SADE SAYAÇLAR -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-4">
        <div class="p-3 rounded" style="background-color: var(--card-purple);">
            <div class=" small fw-bold">TOPLAM KİTAP</div>
            <div class="fs-2 fw-bold text-white">@ViewBag.TotalBooks</div>
        </div>
    </div>
    <div class="col-6 col-md-4">
        <div class="p-3 rounded" style="background-color: var(--card-purple);">
            <div class=" small fw-bold">TOPLAM YAZAR</div>
            <div class="fs-2 fw-bold text-white">@ViewBag.TotalAuthors</div>
        </div>
    </div>
    <div class="col-12 col-md-4">
        <div class="p-3 rounded" style="background-color: var(--card-purple);">
            <div class=" small fw-bold">AKTİF ÖDÜNÇTEKİLER</div>
            <div class="fs-2 fw-bold text-white">@ViewBag.TotalBorrowers</div>
        </div>
    </div>
</div>

<!-- BASİT DURUM RAPOR TABLOLARI -->
<div class="row g-4">

    <!-- 1. Rapor Tablosu: Kitapların Rafta Olma Durumu -->
    <div class="col-md-6">
        <div class="p-3 rounded" style="background-color: var(--card-purple);">
            <h5 class="text-white mb-3 fw-bold small text-uppercase" style="letter-spacing: 0.5px;">
                <i class="bi bi-pie-chart-fill me-2 text-warning"></i>Kitap Dağılım Raporu
            </h5>
            <div class="table-responsive">
                <table class="table table-sm mb-0">
                    <thead>
                        <tr>
                            <th>Durum</th>
                            <th class="text-end">Miktar</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><i class="bi bi-circle-fill me-2 text-success small"></i>Raflarda Hazır Olanlar</td>
                            <td class="text-end fw-bold text-white">@(ViewBag.TotalBooks - ViewBag.TotalBorrowers < 0 ? 0 : ViewBag.TotalBooks - ViewBag.TotalBorrowers)</td>
                        </tr>
                        <tr>
                            <td><i class="bi bi-circle-fill me-2 text-warning small"></i>Üyelerde (Ödünçte) Olanlar</td>
                            <td class="text-end fw-bold text-white">@ViewBag.TotalBorrowers</td>
                        </tr>
                        <tr class="border-top border-secondary">
                            <td class="fw-bold">Genel Toplam Envanter</td>
                            <td class="text-end fw-bold text-purple" style="color: var(--hover-purple)">@ViewBag.TotalBooks</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- 2. Rapor Tablosu: Sistem Durumu Hızlı Linkler -->
    <div class="col-md-6">
        <div class="p-3 rounded" style="background-color: var(--card-purple);">
            <h5 class="text-white mb-3 fw-bold small text-uppercase" style="letter-spacing: 0.5px;">
                <i class="bi bi-lightning-fill me-2 text-info"></i>Hızlı İşlem Raporu
            </h5>
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Modül</th>
                            <th>Mevcut Durum</th>
                            <th class="text-end">İşlem</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>Yazarlar</td>
                            <td class="">@ViewBag.TotalAuthors Kayıtlı</td>
                            <td class="text-end"><a asp-controller="Authors" asp-action="Index" class="btn btn-sm btn-link p-0 text-decoration-none" style="color: var(--hover-purple)">Yönet ></a></td>
                        </tr>
                        <tr>
                            <td>Kitaplar</td>
                            <td class="">@ViewBag.TotalBooks Kayıtlı</td>
                            <td class="text-end"><a asp-controller="Books" asp-action="Index" class="btn btn-sm btn-link p-0 text-decoration-none" style="color: var(--hover-purple)">Yönet ></a></td>
                        </tr>
                        <tr>
                            <td>Ödünç Yapısı</td>
                            <td class="">@ViewBag.TotalBorrowers Aktif Transaksiyon</td>
                            <td class="text-end"><a asp-controller="Borrowers" asp-action="Index" class="btn btn-sm btn-link p-0 text-decoration-none" style="color: var(--hover-purple)">Yönet ></a></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

</div>